#!/usr/bin/env bash
#
# dbx - Database backup and restore utility
# Uses Docker containers for pg_dump/mysqldump (no local install needed)
# Supports SSH tunnels for remote databases (AWS RDS, EC2, etc.)
#
VERSION="0.6.0"
#
# Usage:
#   dbx backup [-v] [--upload] <host> [database]
#   dbx restore <host>/<database>/latest [--name <name>]
#   dbx restore <backup-file> [--name <name>]
#   dbx test <host>
#   dbx list [host] [database]
#   dbx clean [--keep N] [--dry-run] [--older-than D]
#   dbx verify [backup-file]
#   dbx analyze <host> <database>
#   dbx query <host> [database]
#   dbx config init|edit|show|validate
#   dbx vault set|get|list|delete <host>
#   dbx schedule add|remove|list|run
#   dbx storage upload|download|sync|info
#

set -euo pipefail

# ============================================================================
# Source library modules
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/core.sh"
source "$LIB_DIR/tunnel.sh"
source "$LIB_DIR/encrypt.sh"
source "$LIB_DIR/postgres.sh"
source "$LIB_DIR/mysql.sh"
source "$LIB_DIR/notify.sh"
source "$LIB_DIR/schedule.sh"
source "$LIB_DIR/storage.sh"

# ============================================================================
# Commands
# ============================================================================

cmd_backup() {
  local host=""
  local database=""
  local verbose=false
  local upload=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -v|--verbose)
        verbose=true
        shift
        ;;
      --upload)
        upload=true
        shift
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -z "$host" ]]; then
          host="$1"
        elif [[ -z "$database" ]]; then
          database="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$host" ]] && die "Usage: dbx backup [-v] [--upload] <host> [database]"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # If no database specified, backup all databases for this host
  if [[ -z "$database" ]]; then
    local databases
    databases=$(jq -r ".hosts[\"$host\"].databases | keys[]" "$CONFIG_FILE" 2>/dev/null)
    if [[ -z "$databases" ]]; then
      die "No databases configured for host '$host'. Add them with: dbx config edit"
    fi
    log_step "Backing up all databases for $host"
    local db_errors=0
    while IFS= read -r db; do
      log_info "--- $db ---"
      local backup_args=("$host" "$db")
      [[ "$verbose" == "true" ]] && backup_args+=("-v")
      [[ "$upload" == "true" ]] && backup_args+=("--upload")
      cmd_backup "${backup_args[@]}" || ((db_errors++)) || true
    done <<< "$databases"
    if [[ $db_errors -gt 0 ]]; then
      log_error "$db_errors database(s) failed to backup"
      return 1
    fi
    return 0
  fi

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type
  db_type=$(get_db_type "$host")

  # Create backup directory
  local backup_dir="$DATA_DIR/$host/$database"
  mkdir -p "$backup_dir"

  # Generate filename
  local ts
  ts=$(timestamp)
  local backup_file="$backup_dir/${database}_${ts}.sql.zst"

  local backup_rc=0
  case "$db_type" in
    postgres|postgresql)
      pg_backup "$host" "$database" "$backup_file" "$verbose" || backup_rc=$?
      ;;
    mysql|mariadb)
      mysql_backup "$host" "$database" "$backup_file" "$verbose" || backup_rc=$?
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac

  if [[ $backup_rc -ne 0 ]]; then
    notify_backup_failure "$host" "$database" "Backup process exited with code $backup_rc"
    return $backup_rc
  fi

  echo ""
  log_success "Backup complete: $host/$database"

  # Resolve actual backup file path (may have encryption extension)
  local enc_ext
  enc_ext=$(get_encryption_extension)
  local completed_file="$backup_dir/${database}_${ts}.sql.zst${enc_ext}"

  # Send notification
  local completed_size
  completed_size=$(stat -f%z "$completed_file" 2>/dev/null || stat -c%s "$completed_file" 2>/dev/null || echo "0")
  notify_backup_success "$host" "$database" "$completed_file" "$completed_size"

  # Upload to cloud storage if requested or configured
  local auto_upload
  auto_upload=$(get_config_value ".defaults.auto_upload" 2>/dev/null || echo "")
  if [[ "$upload" == "true" || "$auto_upload" == "true" ]]; then
    if is_storage_configured; then
      storage_upload "$completed_file" "$host/$database/$(basename "$completed_file")"
    else
      log_warn "Storage not configured. Skipping upload."
    fi
  fi
}

cmd_restore() {
  local source="${1:-}"
  local target_name=""

  shift || true

  # Parse options
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name|-n)
        target_name="$2"
        shift 2
        ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done

  require_config
  require_jq
  require_docker

  local backup_file=""
  local host=""
  local database=""

  # Fuzzy selection if no source provided or just a host
  if [[ -z "$source" ]] || { [[ -n "$source" ]] && [[ ! -f "$source" ]] && [[ "$source" != */* ]]; }; then
    if ! command -v fzf &>/dev/null; then
      die "Usage: dbx restore <host>/<database>/latest [--name <name>]\n       Install fzf for interactive selection"
    fi

    # Build search path
    local search_dir="$DATA_DIR"
    [[ -n "$source" ]] && search_dir="$DATA_DIR/$source"

    if [[ ! -d "$search_dir" ]]; then
      die "No backups found in: $search_dir"
    fi

    # Find all backup files (including encrypted)
    local backups
    backups=$(find "$search_dir" -type f \( -name "*.sql.zst" -o -name "*.sql.gz" -o -name "*.sql" -o -name "*.sql.zst.gpg" -o -name "*.sql.gz.gpg" -o -name "*.sql.zst.age" -o -name "*.sql.gz.age" \) 2>/dev/null | sort -r)

    if [[ -z "$backups" ]]; then
      die "No backup files found in: $search_dir"
    fi

    # Format for fzf: show relative path, size, date
    local formatted
    formatted=$(echo "$backups" | while read -r f; do
      local rel_path="${f#$DATA_DIR/}"
      local size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
      local date=$(ls -l "$f" 2>/dev/null | awk '{print $6, $7, $8}')
      printf "%-60s %8s  %s\n" "$rel_path" "$size" "$date"
    done)

    # Run fzf
    local selected
    selected=$(echo "$formatted" | fzf \
      --header="Select backup to restore (ESC to cancel)" \
      --prompt="Restore> " \
      --height=80% \
      --layout=reverse \
      --preview="echo 'File: {1}'; echo ''; zstd -dcq '$DATA_DIR/{1}' 2>/dev/null | head -30 || gzip -dc '$DATA_DIR/{1}' 2>/dev/null | head -30 || head -30 '$DATA_DIR/{1}'" \
      --preview-window=right:50%:wrap \
      | awk '{print $1}')

    if [[ -z "$selected" ]]; then
      log_info "Selection cancelled"
      return 0
    fi

    backup_file="$DATA_DIR/$selected"
    # Extract host/database from path
    host=$(echo "$selected" | cut -d'/' -f1)
    database=$(echo "$selected" | cut -d'/' -f2)
  # Parse source - could be path like "production/myapp/latest" or actual file
  elif [[ -f "$source" ]]; then
    backup_file="$source"
    # Try to extract host/database from path
    if [[ "$source" == "$DATA_DIR"/* ]]; then
      local rel_path="${source#$DATA_DIR/}"
      host=$(echo "$rel_path" | cut -d'/' -f1)
      database=$(echo "$rel_path" | cut -d'/' -f2)
    fi
  elif [[ "$source" == */* ]]; then
    # Parse as host/database/selector
    host=$(echo "$source" | cut -d'/' -f1)
    database=$(echo "$source" | cut -d'/' -f2)
    local selector=$(echo "$source" | cut -d'/' -f3)
    selector="${selector:-latest}"

    local backup_dir="$DATA_DIR/$host/$database"
    [[ ! -d "$backup_dir" ]] && die "No backups found for $host/$database"

    if [[ "$selector" == "latest" ]]; then
      # Find latest backup (encrypted or not)
      backup_file=$(ls -t "$backup_dir"/*.sql.zst.age "$backup_dir"/*.sql.zst.gpg "$backup_dir"/*.sql.zst 2>/dev/null | head -1)
    else
      backup_file="$backup_dir/$selector"
    fi

    [[ -z "$backup_file" || ! -f "$backup_file" ]] && die "Backup not found: $backup_file"
  else
    die "Invalid source: $source"
  fi

  [[ ! -f "$backup_file" ]] && die "Backup file not found: $backup_file"

  # Determine target database name
  if [[ -z "$target_name" ]]; then
    local base_name="${database:-$(basename "$backup_file")}"
    base_name="${base_name%.sql.zst.age}"
    base_name="${base_name%.sql.zst.gpg}"
    base_name="${base_name%.sql.zst}"
    base_name="${base_name%%_[0-9]*}"  # Remove timestamp suffix
    local date_suffix
    date_suffix=$(date +"%Y%m%d")

    # Find next available version
    local version=1
    while true; do
      target_name="${base_name}_v${version}_${date_suffix}"
      # Check if database exists (try both postgres and mysql)
      if docker exec "$POSTGRES_CONTAINER" psql -U postgres -lqt 2>/dev/null | grep -qw "$target_name"; then
        ((version++))
      elif docker exec "$MYSQL_CONTAINER" mysql -u root -e "SHOW DATABASES" 2>/dev/null | grep -qw "$target_name"; then
        ((version++))
      else
        break
      fi
    done
  fi

  # Determine database type from metadata or config
  local db_type=""
  local meta_file="${backup_file%.sql.zst}.meta.json"
  if [[ -f "$meta_file" ]]; then
    db_type=$(jq -r '.type' "$meta_file")
  elif [[ -n "$host" ]]; then
    db_type=$(get_db_type "$host")
  else
    # Try to detect from file content
    if decompress "$backup_file" | head -c 100 | grep -q "PostgreSQL"; then
      db_type="postgres"
    else
      db_type="mysql"
    fi
  fi

  log_info "Restoring: $(basename "$backup_file")"
  log_info "Target database: $target_name"

  case "$db_type" in
    postgres|postgresql)
      pg_restore_backup "$backup_file" "$target_name"
      ;;
    mysql|mariadb)
      mysql_restore_backup "$backup_file" "$target_name"
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac

  echo ""
  log_success "Database restored as: $target_name"
  notify_restore_success "$backup_file" "$target_name"
}

cmd_list() {
  local host="${1:-}"
  local database="${2:-}"

  require_jq

  if [[ -n "$host" && -n "$database" ]]; then
    # List backups for specific host/database
    local backup_dir="$DATA_DIR/$host/$database"
    if [[ ! -d "$backup_dir" ]]; then
      log_warn "No backups found for $host/$database"
      return
    fi

    echo -e "${BOLD}Backups for $host/$database:${NC}"
    echo ""
    printf "%-40s %10s %12s\n" "FILENAME" "SIZE" "DATE"
    printf "%-40s %10s %12s\n" "--------" "----" "----"

    for meta in "$backup_dir"/*.meta.json; do
      [[ ! -f "$meta" ]] && continue
      local filename size_bytes size_human timestamp
      filename=$(jq -r '.database + "_" + (.timestamp // "" | split("T")[0]) + ".sql.zst"' "$meta" 2>/dev/null)
      [[ -z "$filename" || "$filename" == "null_" ]] && filename=$(basename "$meta" .meta.json)
      size_bytes=$(jq -r '.size // 0' "$meta")
      size_human=$(human_size "$size_bytes")
      timestamp=$(jq -r '.timestamp // "" | split("T")[0]' "$meta")
      printf "%-40s %10s %12s\n" "$filename" "$size_human" "$timestamp"
    done
  elif [[ -n "$host" ]]; then
    # List databases for host
    local host_dir="$DATA_DIR/$host"
    if [[ ! -d "$host_dir" ]]; then
      log_warn "No backups found for host: $host"
      return
    fi

    echo -e "${BOLD}Databases with backups on $host:${NC}"
    for db_dir in "$host_dir"/*/; do
      [[ -d "$db_dir" ]] && echo "  $(basename "$db_dir")"
    done
  else
    # List all hosts
    if [[ ! -d "$DATA_DIR" ]]; then
      log_warn "No backups found"
      return
    fi

    echo -e "${BOLD}Available backup hosts:${NC}"
    for host_dir in "$DATA_DIR"/*/; do
      if [[ -d "$host_dir" ]]; then
        local h=$(basename "$host_dir")
        local count=$(find "$host_dir" \( -name "*.sql.zst" -o -name "*.sql.zst.gpg" -o -name "*.sql.zst.age" \) 2>/dev/null | wc -l | tr -d ' ')
        echo "  $h ($count backups)"
      fi
    done
  fi
}

cmd_clean() {
  local keep
  keep=$(get_config_value ".defaults.keep_backups" 2>/dev/null || echo "10")
  [[ -z "$keep" || "$keep" == "null" ]] && keep=10
  local dry_run=false
  local older_than_days=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep|-k)
        keep="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      --older-than)
        older_than_days="$2"
        shift 2
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        shift
        ;;
    esac
  done

  [[ "$dry_run" == "true" ]] && log_info "[DRY RUN] No files will be deleted"
  log_step "Cleaning old backups (keeping $keep per database)"

  local total_removed=0
  local total_freed=0

  for host_dir in "$DATA_DIR"/*/; do
    [[ ! -d "$host_dir" ]] && continue
    for db_dir in "$host_dir"/*/; do
      [[ ! -d "$db_dir" ]] && continue

      local backups=()
      while IFS= read -r f; do
        [[ -n "$f" ]] && backups+=("$f")
      done < <(ls -t "$db_dir"/*.sql.zst.age "$db_dir"/*.sql.zst.gpg "$db_dir"/*.sql.zst 2>/dev/null)

      if [[ ${#backups[@]} -gt $keep ]]; then
        local to_remove=("${backups[@]:$keep}")
        for backup in "${to_remove[@]}"; do
          local size meta_file
          size=$(stat -f%z "$backup" 2>/dev/null || stat -c%s "$backup")
          total_freed=$((total_freed + size))
          # Handle both encrypted and non-encrypted meta files
          meta_file="${backup%.age}"
          meta_file="${meta_file%.gpg}"
          meta_file="${meta_file%.sql.zst}.meta.json"
          if [[ "$dry_run" == "true" ]]; then
            log_info "Would remove: $(basename "$backup")"
          else
            rm -f "$backup" "$meta_file"
            log_info "Removed: $(basename "$backup")"
          fi
          ((total_removed++))
        done
      fi

      # Time-based retention (skip backups in the keep set)
      if [[ -n "$older_than_days" ]]; then
        local idx=0
        for backup in "${backups[@]}"; do
          ((idx++))
          # Preserve the newest $keep backups regardless of age
          [[ $idx -le $keep ]] && continue
          # Skip if already removed by count-based retention
          [[ ! -f "$backup" ]] && continue
          local file_age_days
          if is_macos; then
            file_age_days=$(( ($(date +%s) - $(stat -f%m "$backup")) / 86400 ))
          else
            file_age_days=$(( ($(date +%s) - $(stat -c%Y "$backup")) / 86400 ))
          fi
          if [[ $file_age_days -gt $older_than_days ]]; then
            local size meta_file
            size=$(stat -f%z "$backup" 2>/dev/null || stat -c%s "$backup")
            total_freed=$((total_freed + size))
            meta_file="${backup%.age}"
            meta_file="${meta_file%.gpg}"
            meta_file="${meta_file%.sql.zst}.meta.json"
            if [[ "$dry_run" == "true" ]]; then
              log_info "Would remove (${file_age_days}d old): $(basename "$backup")"
            else
              rm -f "$backup" "$meta_file"
              log_info "Removed (${file_age_days}d old): $(basename "$backup")"
            fi
            ((total_removed++))
          fi
        done
      fi
    done
  done

  if [[ $total_removed -gt 0 ]]; then
    if [[ "$dry_run" == "true" ]]; then
      log_info "Would remove $total_removed backups, freeing $(human_size $total_freed)"
    else
      log_success "Removed $total_removed backups, freed $(human_size $total_freed)"
    fi
  else
    log_info "No old backups to remove"
  fi
}

cmd_vault() {
  local action="${1:-}"
  local host="${2:-}"

  case "$action" in
    set)
      [[ -z "$host" ]] && die "Usage: dbx vault set <host>"

      require_config
      require_jq

      # Get host info from config
      local db_host db_port db_user db_type
      db_type=$(get_config_value ".hosts[\"$host\"].type")
      db_host=$(get_config_value ".hosts[\"$host\"].host")
      db_port=$(get_config_value ".hosts[\"$host\"].port")
      db_user=$(get_config_value ".hosts[\"$host\"].user")

      [[ -z "$db_type" ]] && die "Host '$host' not found in config. Run: dbx config edit"

      echo -e "${BOLD}Setting credentials for: $host${NC}"
      echo "  Type: $db_type"
      echo "  Host: $db_host:$db_port"
      echo "  User: $db_user"
      echo ""

      # Prompt for password
      echo -n "Password: "
      read -rs password
      echo ""

      if [[ -z "$password" ]]; then
        die "Password cannot be empty"
      fi

      # Store in keychain
      keychain_set "$host" "$password"
      audit_vault "set" "$host" "success"
      log_success "Credentials stored for: $host"
      log_info "Password will be retrieved automatically during backup"
      ;;

    get)
      [[ -z "$host" ]] && die "Usage: dbx vault get <host>"
      local pass
      pass=$(keychain_get "$host" 2>/dev/null || true)
      if [[ -n "$pass" ]]; then
        echo "$pass"
      else
        die "No credentials found for: $host"
      fi
      ;;

    delete|rm)
      [[ -z "$host" ]] && die "Usage: dbx vault delete <host>"
      if keychain_delete "$host"; then
        log_success "Credentials removed for: $host"
        audit_vault "delete" "$host" "success"
      else
        log_warn "No credentials found for: $host"
      fi
      ;;

    list|ls)
      echo -e "${BOLD}Stored credentials:${NC}"
      local hosts
      hosts=$(keychain_list)
      if [[ -n "$hosts" ]]; then
        echo "$hosts" | while read -r h; do
          [[ "$h" == "_dbx_encryption_key" ]] && continue
          echo "  $h"
        done
      else
        echo "  (none)"
      fi
      # Check encryption key
      if get_encryption_key &>/dev/null; then
        echo ""
        echo -e "${BOLD}Encryption:${NC}"
        echo "  Key is set"
      fi
      ;;

    set-encryption-key)
      echo -e "${BOLD}Setting encryption key for backups${NC}"
      echo ""
      echo "This passphrase will be used to encrypt all backups."
      echo "Store it safely - you cannot recover backups without it!"
      echo ""

      echo -n "Encryption passphrase: "
      read -rs passphrase
      echo ""

      if [[ -z "$passphrase" ]]; then
        die "Passphrase cannot be empty"
      fi

      echo -n "Confirm passphrase: "
      read -rs passphrase_confirm
      echo ""

      if [[ "$passphrase" != "$passphrase_confirm" ]]; then
        die "Passphrases do not match"
      fi

      set_encryption_key "$passphrase"
      audit_vault "set" "encryption_key" "success"
      log_success "Encryption key stored"
      log_info "Enable encryption in config: dbx config edit"
      log_info "Set \"encryption\": true in defaults section"
      ;;

    delete-encryption-key)
      if delete_encryption_key; then
        log_success "Encryption key removed"
      else
        log_warn "No encryption key found"
      fi
      ;;

    info)
      vault_info
      ;;

    init-age|init-encryption)
      require_age
      init_age_encryption
      ;;

    *)
      die "Usage: dbx vault <set|get|delete|list|info|set-encryption-key|init-age> [host]"
      ;;
  esac
}

cmd_config() {
  local action="${1:-show}"

  case "$action" in
    init)
      mkdir -p "$CONFIG_DIR"
      if [[ -f "$CONFIG_FILE" ]]; then
        log_warn "Config already exists: $CONFIG_FILE"
        return
      fi

      cat > "$CONFIG_FILE" <<'EOF'
{
  "hosts": {
    "example-mysql": {
      "type": "mysql",
      "user": "backup_user",
      "definer_handling": "strip",
      "ssh_tunnel": {
        "jump_host": "bastion-server",
        "target_host": "mysql.internal",
        "target_port": 3306
      },
      "databases": {
        "myapp": {
          "exclude_data": ["sessions", "cache", "jobs"]
        }
      }
    },
    "example-rds": {
      "type": "mysql",
      "user": "admin",
      "definer_handling": "strip",
      "ssh_tunnel": {
        "jump_host": "bastion",
        "target_host": "mydb.xxxx.us-east-1.rds.amazonaws.com",
        "target_port": 3306
      },
      "databases": {
        "production": {
          "exclude_data": ["audit_logs", "sessions"]
        }
      }
    },
    "local": {
      "type": "postgres",
      "host": "localhost",
      "port": 5432,
      "user": "postgres",
      "databases": {
        "devdb": {}
      }
    }
  },
  "defaults": {
    "compression": "zstd",
    "compression_level": 3,
    "parallel_jobs": 4,
    "keep_backups": 10,
    "definer_handling": "strip",
    "encryption": false
  }
}
EOF
      log_success "Config created: $CONFIG_FILE"
      secure_file "$CONFIG_FILE"
      log_info "Edit it with: dbx config edit"
      log_info "Store passwords with: dbx vault set <host>"
      ;;

    edit)
      require_config
      "${EDITOR:-vim}" "$CONFIG_FILE"
      # Validate JSON after editing
      if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        log_error "Config file contains invalid JSON!"
        log_warn "Fix it with: dbx config edit"
      else
        log_success "Config is valid JSON"
      fi
      ;;

    show)
      require_config
      require_jq
      jq '.' "$CONFIG_FILE"
      ;;

    validate)
      require_config
      require_jq

      local errors=0

      # Check valid JSON
      if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        log_error "Config file is not valid JSON"
        return 1
      fi
      log_success "Valid JSON"

      # Check hosts exist
      local host_count
      host_count=$(jq '.hosts | length' "$CONFIG_FILE")
      if [[ "$host_count" -eq 0 ]]; then
        log_warn "No hosts configured"
      else
        log_success "$host_count host(s) configured"
      fi

      # Validate each host
      local hosts
      hosts=$(jq -r '.hosts | keys[]' "$CONFIG_FILE")
      while IFS= read -r h; do
        local htype huser
        htype=$(jq -r ".hosts[\"$h\"].type // empty" "$CONFIG_FILE")
        huser=$(jq -r ".hosts[\"$h\"].user // empty" "$CONFIG_FILE")

        if [[ -z "$htype" ]]; then
          log_error "Host '$h': missing 'type' (postgres or mysql)"
          ((errors++))
        elif [[ "$htype" != "postgres" && "$htype" != "postgresql" && "$htype" != "mysql" && "$htype" != "mariadb" ]]; then
          log_error "Host '$h': invalid type '$htype' (use postgres or mysql)"
          ((errors++))
        fi

        if [[ -z "$huser" ]]; then
          log_error "Host '$h': missing 'user'"
          ((errors++))
        fi

        # Check if a password source exists (without invoking external commands)
        local has_vault has_cmd has_plain
        has_vault=$(keychain_get "$h" 2>/dev/null || true)
        has_cmd=$(get_config_value ".hosts[\"$h\"].password_cmd" 2>/dev/null || true)
        has_plain=$(get_config_value ".hosts[\"$h\"].password" 2>/dev/null || true)
        if [[ -z "$has_vault" && -z "$has_cmd" && -z "$has_plain" ]]; then
          log_warn "Host '$h': no password source found (vault, password_cmd, or config)"
        fi
      done <<< "$hosts"

      # Check encryption config coherence
      local enc_type
      enc_type=$(get_encryption_type 2>/dev/null || echo "none")
      if [[ "$enc_type" == "age" ]]; then
        local recipients
        recipients=$(get_age_recipients_file)
        if [[ ! -f "$recipients" ]]; then
          log_error "Encryption type 'age' but recipients file missing: $recipients"
          log_info "Run: dbx vault init-age"
          ((errors++))
        else
          log_success "Age encryption configured"
        fi
      elif [[ "$enc_type" == "gpg" ]]; then
        if ! get_encryption_key &>/dev/null; then
          log_error "Encryption type 'gpg' but no encryption key set"
          log_info "Run: dbx vault set-encryption-key"
          ((errors++))
        else
          log_success "GPG encryption configured"
        fi
      fi

      if [[ $errors -gt 0 ]]; then
        echo ""
        log_error "$errors error(s) found"
        return 1
      else
        echo ""
        log_success "Config validation passed"
      fi
      ;;

    *)
      die "Unknown config action: $action (use: init, edit, show, validate)"
      ;;
  esac
}

cmd_analyze() {
  local host="${1:-}"
  local database="${2:-}"

  [[ -z "$host" ]] && die "Usage: dbx analyze <host> <database>"
  [[ -z "$database" ]] && die "Usage: dbx analyze <host> <database>"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type
  db_type=$(get_db_type "$host")

  case "$db_type" in
    mysql|mariadb)
      analyze_mysql "$host" "$database"
      ;;
    postgres|postgresql)
      analyze_postgres "$host" "$database"
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac
}

cmd_verify() {
  local backup_file="${1:-}"

  if [[ -z "$backup_file" ]]; then
    # Interactive selection
    if command -v fzf &>/dev/null && [[ -d "$DATA_DIR" ]]; then
      local backups
      backups=$(find "$DATA_DIR" -type f \( -name "*.sql.zst" -o -name "*.sql.zst.gpg" -o -name "*.sql.zst.age" \) 2>/dev/null | sort -r)

      if [[ -n "$backups" ]]; then
        local formatted
        formatted=$(echo "$backups" | while read -r f; do
          local rel size
          rel="${f#$DATA_DIR/}"
          size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
          printf "%-60s %8s\n" "$rel" "$size"
        done)

        local selected
        selected=$(echo "$formatted" | fzf --header="Select backup to verify:" --prompt="Verify> " | awk '{print $1}')
        [[ -z "$selected" ]] && return 0
        backup_file="$DATA_DIR/$selected"
      fi
    fi
  fi

  [[ -z "$backup_file" ]] && die "Usage: dbx verify <backup-file>"
  [[ ! -f "$backup_file" ]] && die "File not found: $backup_file"

  require_jq

  verify_backup "$backup_file"
}

cmd_schedule() {
  local action="${1:-list}"
  shift || true

  case "$action" in
    add)
      local host="${1:-}"
      local database="${2:-}"
      local schedule="${3:-daily}"

      [[ -z "$host" ]] && die "Usage: dbx schedule add <host> <database> [schedule]"
      [[ -z "$database" ]] && die "Usage: dbx schedule add <host> <database> [schedule]"

      require_config
      schedule_add "$host" "$database" "$schedule"
      ;;

    remove|rm|delete)
      local host="${1:-}"
      local database="${2:-}"

      [[ -z "$host" ]] && die "Usage: dbx schedule remove <host> <database>"
      [[ -z "$database" ]] && die "Usage: dbx schedule remove <host> <database>"

      schedule_remove "$host" "$database"
      ;;

    run)
      local host="${1:-}"
      local database="${2:-}"

      [[ -z "$host" ]] && die "Usage: dbx schedule run <host> <database>"
      [[ -z "$database" ]] && die "Usage: dbx schedule run <host> <database>"

      schedule_run "$host" "$database"
      ;;

    list|ls|"")
      schedule_list
      ;;

    *)
      die "Unknown schedule action: $action (use: add, remove, list, run)"
      ;;
  esac
}

cmd_storage() {
  local action="${1:-info}"
  shift || true

  case "$action" in
    upload)
      local local_file="${1:-}"
      local remote_path="${2:-}"

      [[ -z "$local_file" ]] && die "Usage: dbx storage upload <local-file> [remote-path]"
      [[ ! -f "$local_file" ]] && die "File not found: $local_file"

      storage_upload "$local_file" "$remote_path"
      ;;

    download)
      local remote_path="${1:-}"
      local local_file="${2:-}"

      [[ -z "$remote_path" ]] && die "Usage: dbx storage download <remote-path> [local-file]"

      local result
      result=$(storage_download "$remote_path" "$local_file")
      log_info "Downloaded to: $result"
      ;;

    list|ls)
      local path="${1:-}"
      storage_list "$path"
      ;;

    delete|rm)
      local remote_path="${1:-}"
      [[ -z "$remote_path" ]] && die "Usage: dbx storage delete <remote-path>"
      storage_delete "$remote_path"
      ;;

    sync)
      local direction="${1:-upload}"
      local host="${2:-}"
      local database="${3:-}"

      case "$direction" in
        upload|up)
          [[ -z "$host" ]] && die "Usage: dbx storage sync upload <host> [database]"
          storage_sync_upload "$host" "$database"
          ;;
        download|down)
          [[ -z "$host" ]] && die "Usage: dbx storage sync download <host> [database]"
          storage_sync_download "$host" "$database"
          ;;
        *)
          die "Usage: dbx storage sync <upload|download> <host> [database]"
          ;;
      esac
      ;;

    info|"")
      storage_info
      ;;

    *)
      die "Unknown storage action: $action (use: upload, download, list, delete, sync, info)"
      ;;
  esac
}

cmd_query() {
  local host="${1:-}"
  local database="${2:-}"

  [[ -z "$host" ]] && die "Usage: dbx query <host> [database]"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type db_host db_port db_user db_pass
  db_type=$(get_db_type "$host")
  db_host=$(get_effective_host "$host")
  db_port=$(get_effective_port "$host")
  db_user=$(get_config_value ".hosts[\"$host\"].user")
  db_pass=$(get_password "$host")

  log_step "Connecting to $host ($db_type)"
  log_info "Host: $db_host:$db_port, User: $db_user"
  [[ -n "$database" ]] && log_info "Database: $database"

  case "$db_type" in
    postgres|postgresql)
      require_container "$POSTGRES_CONTAINER"
      if [[ -n "$database" ]]; then
        docker exec -it -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
          psql -h "$db_host" -p "$db_port" -U "$db_user" -d "$database"
      else
        docker exec -it -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
          psql -h "$db_host" -p "$db_port" -U "$db_user"
      fi
      ;;
    mysql|mariadb)
      require_container "$MYSQL_CONTAINER"
      if [[ -n "$database" ]]; then
        docker exec -it -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
          mysql -h "$db_host" -P "$db_port" -u "$db_user" "$database"
      else
        docker exec -it -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
          mysql -h "$db_host" -P "$db_port" -u "$db_user"
      fi
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac
}

cmd_test() {
  local host="${1:-}"

  [[ -z "$host" ]] && die "Usage: dbx test <host>"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  log_step "Testing connection to: $host"

  local db_type db_host db_port db_user
  db_type=$(get_db_type "$host")
  db_host=$(get_config_value ".hosts[\"$host\"].host")
  db_port=$(get_config_value ".hosts[\"$host\"].port")
  db_user=$(get_config_value ".hosts[\"$host\"].user")

  # Test 1: SSH tunnel (if configured)
  if has_ssh_tunnel "$host"; then
    log_info "SSH tunnel configured"
    if create_ssh_tunnel "$host"; then
      log_success "SSH tunnel established"
    else
      log_error "SSH tunnel failed"
      return 1
    fi
    db_host=$(get_effective_host "$host")
    db_port=$(get_effective_port "$host")
  else
    log_info "No SSH tunnel (direct connection)"
  fi

  # Test 2: Docker container
  case "$db_type" in
    postgres|postgresql)
      log_info "Checking PostgreSQL container..."
      require_container "$POSTGRES_CONTAINER"
      log_success "Container ready: $POSTGRES_CONTAINER"
      ;;
    mysql|mariadb)
      log_info "Checking MySQL container..."
      require_container "$MYSQL_CONTAINER"
      log_success "Container ready: $MYSQL_CONTAINER"
      ;;
  esac

  # Test 3: Credentials
  local db_pass
  db_pass=$(get_password "$host" 2>/dev/null || true)
  if [[ -n "$db_pass" ]]; then
    log_success "Credentials found"
  else
    log_error "No credentials found for '$host'"
    log_info "Set with: dbx vault set $host"
    return 1
  fi

  # Test 4: Database connectivity
  log_info "Testing database connection..."
  case "$db_type" in
    postgres|postgresql)
      if docker exec -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
        psql -h "$db_host" -p "$db_port" -U "$db_user" -c "SELECT 1" >/dev/null 2>&1; then
        log_success "PostgreSQL connection successful"
      else
        log_error "PostgreSQL connection failed"
        return 1
      fi
      ;;
    mysql|mariadb)
      if docker exec -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
        mysqladmin ping -h "$db_host" -P "$db_port" -u "$db_user" >/dev/null 2>&1; then
        log_success "MySQL connection successful"
      else
        log_error "MySQL connection failed"
        return 1
      fi
      ;;
  esac

  # Test 5: List available databases
  log_info "Available databases:"
  case "$db_type" in
    postgres|postgresql)
      docker exec -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
        psql -h "$db_host" -p "$db_port" -U "$db_user" -t -A -c \
        "SELECT datname FROM pg_database WHERE datistemplate = false ORDER BY datname" 2>/dev/null | \
        while read -r dbname; do echo "  - $dbname"; done
      ;;
    mysql|mariadb)
      docker exec -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
        mysql -h "$db_host" -P "$db_port" -u "$db_user" -N -e "SHOW DATABASES" 2>/dev/null | \
        grep -v -E "^(information_schema|performance_schema|mysql|sys)$" | \
        while read -r dbname; do echo "  - $dbname"; done
      ;;
  esac

  echo ""
  log_success "All connection tests passed for: $host"
}

# ============================================================================
# TUI Mode (requires gum)
# ============================================================================

require_gum() {
  command -v gum &>/dev/null || die "gum is required for TUI mode. Install: brew install gum (or go install github.com/charmbracelet/gum@latest)"
}

# Check for updates (cached for session)
LATEST_VERSION=""
check_for_updates() {
  if [[ -z "$LATEST_VERSION" ]]; then
    LATEST_VERSION=$(curl -fsSL --connect-timeout 2 "https://raw.githubusercontent.com/steig/dbx/main/dbx" 2>/dev/null | grep '^VERSION=' | cut -d'"' -f2 || echo "")
  fi
  if [[ -n "$LATEST_VERSION" && "$LATEST_VERSION" != "$VERSION" ]]; then
    return 0  # Update available
  fi
  return 1  # No update
}

run_self_update() {
  echo ""
  gum style --foreground 39 --bold "  Updating dbx..."
  echo ""
  if curl -fsSL https://raw.githubusercontent.com/steig/dbx/main/install.sh | bash; then
    echo ""
    gum style --foreground 40 --bold "  ✓ Updated! Please restart dbx tui"
    sleep 2
    exit 0
  else
    gum style --foreground 196 --bold "  ✗ Update failed"
    sleep 2
  fi
}

list_hosts() {
  require_config
  require_jq
  jq -r '.hosts | keys[]' "$CONFIG_FILE"
}

list_databases_for_host() {
  local host="$1"
  require_jq
  jq -r ".hosts[\"$host\"].databases | keys[]" "$CONFIG_FILE" 2>/dev/null
}

tui_header() {
  clear
  gum style \
    --border double \
    --border-foreground 99 \
    --padding "0 2" \
    --margin "0 0 1 0" \
    --bold \
    --foreground 99 \
    "  dbx $VERSION  Database Backup & Restore"
}

tui_dashboard() {
  tui_header

  # Hosts section
  local hosts
  hosts=$(list_hosts 2>/dev/null || true)

  if [[ -z "$hosts" ]]; then
    echo "No hosts configured. Run: dbx config edit" | gum style \
      --border rounded --border-foreground 39 --padding "1 2" --width 60
  else
    {
      printf "%-18s %-10s %-10s %s\n" "HOST" "TYPE" "DATABASES" "BACKUPS"
      echo "───────────────────────────────────────────────────────"
      while IFS= read -r host; do
        local htype dbs_count backup_count
        htype=$(get_db_type "$host" 2>/dev/null || echo "?")
        dbs_count=$(list_databases_for_host "$host" 2>/dev/null | wc -l | tr -d ' ')
        backup_count=$(find "$DATA_DIR/$host" -name "*.sql.zst*" 2>/dev/null | wc -l | tr -d ' ')
        printf "%-18s %-10s %-10s %s\n" "$host" "$htype" "${dbs_count:-0} dbs" "${backup_count:-0} files"
      done <<< "$hosts"
    } | gum style --border rounded --border-foreground 39 --padding "1 2" --width 60
  fi

  echo ""

  # Recent backups section
  if [[ -d "$DATA_DIR" ]]; then
    local backup_files
    backup_files=$(find "$DATA_DIR" -name "*.sql.zst*" -type f 2>/dev/null | head -5)
    if [[ -n "$backup_files" ]]; then
      {
        printf "%-38s %8s\n" "RECENT BACKUPS" "SIZE"
        echo "───────────────────────────────────────────────────────"
        while IFS= read -r f; do
          [[ -z "$f" ]] && continue
          local rel size lock=""
          rel="${f#$DATA_DIR/}"
          size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
          [[ "$f" == *.gpg || "$f" == *.age ]] && lock=" 🔒"
          printf "%-38s %8s%s\n" "${rel:0:38}" "$size" "$lock"
        done <<< "$backup_files"
      } | gum style --border rounded --border-foreground 220 --padding "1 2" --width 60
    else
      echo "No backups yet" | gum style --border rounded --border-foreground 220 --padding "1 2" --width 60
    fi
  else
    echo "No backups yet" | gum style --border rounded --border-foreground 220 --padding "1 2" --width 60
  fi

  echo ""

  # Storage info
  local storage_info="Backups: $DATA_DIR"
  if [[ -d "$DATA_DIR" ]]; then
    local total_size total_count
    total_size=$(du -sh "$DATA_DIR" 2>/dev/null | cut -f1 || echo "0B")
    total_count=$(find "$DATA_DIR" -name "*.sql.zst*" 2>/dev/null | wc -l | tr -d ' ')
    storage_info="Total: ${total_count:-0} backups (${total_size})"
  fi
  if is_encryption_enabled 2>/dev/null; then
    storage_info+="  🔒 Encrypted"
  fi
  gum style --faint "  $storage_info"

  # Check for updates
  if check_for_updates; then
    echo ""
    echo "⚡ Update: $VERSION → $LATEST_VERSION (select Update)" | gum style \
      --border rounded --border-foreground 208 --foreground 208 --bold --padding "0 2" --width 60
  fi
  echo ""
}

tui_action_menu() {
  local options=(
    "⬆  Backup database"
    "⬇  Restore backup"
    "⌨  Query database"
    "📊 Analyze tables"
    "📋 List all backups"
    "🧹 Clean old backups"
    "🔑 Vault & credentials"
    "⚙  Configuration"
  )

  # Add update option if available
  if check_for_updates; then
    options+=("⚡ Update to $LATEST_VERSION")
  fi

  options+=("❌ Quit")

  printf '%s\n' "${options[@]}" | gum choose --height 12 --cursor "▸ " --cursor-prefix "" --selected-prefix "▸ " --unselected-prefix "  "
}

tui_select_host() {
  local hosts
  hosts=$(list_hosts)
  if [[ -z "$hosts" ]]; then
    gum style --foreground 196 --bold "  No hosts configured!"
    sleep 1
    return 1
  fi

  local host_options=""
  while IFS= read -r host; do
    local htype
    htype=$(get_db_type "$host" 2>/dev/null)
    host_options+="$host ($htype)"$'\n'
  done <<< "$hosts"

  local selected
  selected=$(echo "$host_options" | gum choose --header "Select host:")
  echo "$selected" | sed 's/ (.*//'
}

tui_select_backup() {
  if [[ ! -d "$DATA_DIR" ]]; then
    gum style --foreground 196 "No backups found"
    return 1
  fi

  local backups
  backups=$(find "$DATA_DIR" -type f \( -name "*.sql.zst" -o -name "*.sql.zst.gpg" -o -name "*.sql.zst.age" \) 2>/dev/null | xargs ls -t 2>/dev/null)
  if [[ -z "$backups" ]]; then
    gum style --foreground 196 "No backup files found"
    return 1
  fi

  local formatted=""
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    local rel size date lock=""
    rel="${f#$DATA_DIR/}"
    size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
    date=$(ls -l "$f" 2>/dev/null | awk '{print $6, $7}')
    [[ "$f" == *.gpg || "$f" == *.age ]] && lock="🔒 "
    formatted+="${lock}${rel} (${size}, ${date})"$'\n'
  done <<< "$backups"

  local selected
  selected=$(echo "$formatted" | gum filter --height 15 --header "Select backup (type to filter):")
  [[ -z "$selected" ]] && return 1

  # Extract path (remove lock emoji, size, date)
  echo "$selected" | sed 's/^🔒 //' | sed 's/ ([^)]*,[^)]*)$//'
}

cmd_tui() {
  require_gum
  require_config
  require_jq

  while true; do
    tui_dashboard

    local action
    action=$(tui_action_menu)

    case "$action" in
      "⬆  Backup database")
        echo ""
        local host
        host=$(tui_select_host) || continue
        [[ -z "$host" ]] && continue

        local databases db
        databases=$(list_databases_for_host "$host")
        if [[ -n "$databases" ]]; then
          db=$(echo "$databases" | gum choose --header "Select database:")
        fi
        if [[ -z "$db" ]]; then
          db=$(gum input --placeholder "Enter database name" --header "Database:")
        fi
        [[ -z "$db" ]] && continue

        echo ""
        gum spin --spinner dot --title "Backing up $host/$db..." -- dbx backup "$host" "$db"
        gum style --foreground 40 --bold "  ✓ Backup complete!"
        sleep 2
        ;;

      "⬇  Restore backup")
        echo ""
        local selected
        selected=$(tui_select_backup) || continue
        [[ -z "$selected" ]] && continue

        local target
        target=$(gum input --placeholder "Leave empty for auto-generated name" --header "Target database name:")

        echo ""
        if [[ -n "$target" ]]; then
          gum spin --spinner dot --title "Restoring to $target..." -- dbx restore "$DATA_DIR/$selected" --name "$target"
        else
          gum spin --spinner dot --title "Restoring backup..." -- dbx restore "$DATA_DIR/$selected"
        fi
        gum style --foreground 40 --bold "  ✓ Restore complete!"
        sleep 2
        ;;

      "⌨  Query database")
        echo ""
        local host
        host=$(tui_select_host) || continue
        [[ -z "$host" ]] && continue

        local db
        db=$(gum input --placeholder "Leave empty for no database" --header "Database (optional):")

        echo ""
        gum style --foreground 212 --bold "  Opening SQL session... (\\q or Ctrl+D to exit)"
        sleep 1
        if [[ -n "$db" ]]; then
          dbx query "$host" "$db"
        else
          dbx query "$host"
        fi
        ;;

      "📊 Analyze tables")
        echo ""
        local host
        host=$(tui_select_host) || continue
        [[ -z "$host" ]] && continue

        local db
        db=$(gum input --placeholder "Database name" --header "Database:")
        [[ -z "$db" ]] && continue

        dbx analyze "$host" "$db"
        echo ""
        gum input --placeholder "Press Enter to continue..."
        ;;

      "📋 List all backups")
        tui_header
        echo ""
        dbx list
        echo ""
        gum input --placeholder "Press Enter to continue..."
        ;;

      "🧹 Clean old backups")
        echo ""
        local keep
        keep=$(gum input --value "10" --header "Keep how many backups per database?")
        [[ -z "$keep" ]] && keep=10

        if gum confirm "Remove old backups, keeping $keep per database?"; then
          echo ""
          dbx clean --keep "$keep"
          sleep 2
        fi
        ;;

      "🔑 Vault & credentials")
        while true; do
          tui_header
          gum style --border rounded --border-foreground 135 --padding "1 2" --width 50 \
            --bold --foreground 135 "VAULT & CREDENTIALS"

          local vault_action
          vault_action=$(gum choose --cursor "▸ " \
            "📋 List stored credentials" \
            "➕ Set host password" \
            "➖ Delete host password" \
            "🔐 Set encryption key" \
            "← Back")

          case "$vault_action" in
            "📋 List stored credentials")
              echo ""
              dbx vault list
              echo ""
              gum input --placeholder "Press Enter to continue..."
              ;;
            "➕ Set host password")
              echo ""
              local host
              host=$(tui_select_host) || continue
              [[ -n "$host" ]] && dbx vault set "$host"
              sleep 1
              ;;
            "➖ Delete host password")
              echo ""
              local host
              host=$(gum input --header "Host name to delete:")
              [[ -n "$host" ]] && dbx vault delete "$host"
              sleep 1
              ;;
            "🔐 Set encryption key")
              echo ""
              dbx vault set-encryption-key
              sleep 1
              ;;
            "← Back"|"")
              break
              ;;
          esac
        done
        ;;

      "⚙  Configuration")
        while true; do
          tui_header
          gum style --border rounded --border-foreground 208 --padding "1 2" --width 50 \
            --bold --foreground 208 "CONFIGURATION & MANAGEMENT"

          local config_action
          config_action=$(gum choose --cursor "▸ " \
            "➕ Add host" \
            "➖ Remove host" \
            "📁 Add database to host" \
            "🗑  Delete backups" \
            "✏  Edit config (advanced)" \
            "👁  Show config" \
            "🆕 Initialize config" \
            "← Back")

          case "$config_action" in
            "➕ Add host")
              echo ""
              local new_host new_type new_user new_hostaddr new_port

              new_host=$(gum input --header "Host alias (e.g., production):" --placeholder "production")
              [[ -z "$new_host" ]] && continue

              new_type=$(gum choose --header "Database type:" "postgres" "mysql")
              [[ -z "$new_type" ]] && continue

              new_user=$(gum input --header "Database user:" --placeholder "postgres")
              [[ -z "$new_user" ]] && continue

              new_hostaddr=$(gum input --header "Host address:" --placeholder "localhost or db.internal")
              [[ -z "$new_hostaddr" ]] && continue

              new_port=$(gum input --header "Port:" --value "$([[ "$new_type" == "postgres" ]] && echo "5432" || echo "3306")")

              # Add to config using jq
              local tmp_config
              tmp_config=$(mktemp)
              jq ".hosts[\"$new_host\"] = {type: \"$new_type\", host: \"$new_hostaddr\", port: $new_port, user: \"$new_user\", databases: {}}" "$CONFIG_FILE" > "$tmp_config" && mv "$tmp_config" "$CONFIG_FILE"

              gum style --foreground 40 --bold "  ✓ Host '$new_host' added!"

              if gum confirm "Set password for this host now?"; then
                dbx vault set "$new_host"
              fi
              sleep 1
              ;;

            "➖ Remove host")
              echo ""
              local host
              host=$(tui_select_host) || continue
              [[ -z "$host" ]] && continue

              if gum confirm --default=false "Remove host '$host' from config?"; then
                local tmp_config
                tmp_config=$(mktemp)
                jq "del(.hosts[\"$host\"])" "$CONFIG_FILE" > "$tmp_config" && mv "$tmp_config" "$CONFIG_FILE"
                gum style --foreground 40 --bold "  ✓ Host '$host' removed!"
                sleep 1
              fi
              ;;

            "📁 Add database to host")
              echo ""
              local host
              host=$(tui_select_host) || continue
              [[ -z "$host" ]] && continue

              local new_db
              new_db=$(gum input --header "Database name:" --placeholder "myapp")
              [[ -z "$new_db" ]] && continue

              local exclude_tables=""
              if gum confirm "Add tables to exclude from data dump?"; then
                exclude_tables=$(gum input --header "Tables to exclude (comma-separated):" --placeholder "sessions, cache, logs")
              fi

              # Add to config using jq
              local tmp_config
              tmp_config=$(mktemp)
              if [[ -n "$exclude_tables" ]]; then
                local exclude_json
                exclude_json=$(echo "$exclude_tables" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | jq -R . | jq -s .)
                jq ".hosts[\"$host\"].databases[\"$new_db\"] = {exclude_data: $exclude_json}" "$CONFIG_FILE" > "$tmp_config" && mv "$tmp_config" "$CONFIG_FILE"
              else
                jq ".hosts[\"$host\"].databases[\"$new_db\"] = {}" "$CONFIG_FILE" > "$tmp_config" && mv "$tmp_config" "$CONFIG_FILE"
              fi

              gum style --foreground 40 --bold "  ✓ Database '$new_db' added to '$host'!"
              sleep 1
              ;;

            "🗑  Delete backups")
              echo ""
              if [[ ! -d "$DATA_DIR" ]]; then
                gum style --foreground 196 "No backups found"
                sleep 1
                continue
              fi

              local delete_choice
              delete_choice=$(gum choose --header "Delete backups:" \
                "Select specific backup" \
                "Delete all for a host" \
                "Delete all for a database" \
                "Cancel")

              case "$delete_choice" in
                "Select specific backup")
                  local selected
                  selected=$(tui_select_backup) || continue
                  [[ -z "$selected" ]] && continue

                  if gum confirm --default=false "Delete backup: $selected?"; then
                    rm -f "$DATA_DIR/$selected"
                    rm -f "$DATA_DIR/${selected%.sql.zst*}.meta.json"
                    gum style --foreground 40 --bold "  ✓ Backup deleted!"
                  fi
                  ;;
                "Delete all for a host")
                  local host
                  host=$(tui_select_host) || continue
                  [[ -z "$host" ]] && continue

                  local count
                  count=$(find "$DATA_DIR/$host" -name "*.sql.zst*" 2>/dev/null | wc -l | tr -d ' ')

                  if gum confirm --default=false "Delete ALL $count backups for '$host'?"; then
                    rm -rf "$DATA_DIR/$host"
                    gum style --foreground 40 --bold "  ✓ All backups for '$host' deleted!"
                  fi
                  ;;
                "Delete all for a database")
                  local host
                  host=$(tui_select_host) || continue
                  [[ -z "$host" ]] && continue

                  local dbs
                  dbs=$(ls -1 "$DATA_DIR/$host" 2>/dev/null)
                  if [[ -z "$dbs" ]]; then
                    gum style --foreground 196 "No backups for this host"
                    continue
                  fi

                  local db
                  db=$(echo "$dbs" | gum choose --header "Select database:")
                  [[ -z "$db" ]] && continue

                  local count
                  count=$(find "$DATA_DIR/$host/$db" -name "*.sql.zst*" 2>/dev/null | wc -l | tr -d ' ')

                  if gum confirm --default=false "Delete ALL $count backups for '$host/$db'?"; then
                    rm -rf "$DATA_DIR/$host/$db"
                    gum style --foreground 40 --bold "  ✓ All backups for '$host/$db' deleted!"
                  fi
                  ;;
              esac
              sleep 1
              ;;

            "👁  Show config")
              tui_header
              dbx config show
              echo ""
              gum input --placeholder "Press Enter to continue..."
              ;;
            "✏  Edit config (advanced)")
              dbx config edit
              ;;
            "🆕 Initialize config")
              dbx config init
              sleep 2
              ;;
            "← Back"|"")
              break
              ;;
          esac
        done
        ;;

      "⚡ Update"*)
        run_self_update
        ;;

      "❌ Quit"|"")
        clear
        break
        ;;
    esac
  done
}

cmd_help() {
  cat <<EOF
${BOLD}dbx${NC} - Database backup and restore utility

${BOLD}USAGE:${NC}
  dbx <command> [options]

${BOLD}COMMANDS:${NC}
  tui                          Interactive TUI mode (requires gum)
  backup [-v] [--upload] <host> [database]  Backup database(s) (-v verbose)
  restore <source> [--name N]  Restore a backup to local container
  verify [backup-file]         Verify backup integrity (checksum)
  query <host> [database]      Open interactive shell to remote database
  analyze <host> <database>    Interactive table analysis & exclusion picker
  test <host>                  Test connection to a database host
  list [host] [database]       List available backups
  clean [--keep N] [--dry-run] [--older-than D]  Remove old backups

${BOLD}CREDENTIAL & ENCRYPTION:${NC}
  vault set|get|delete|list    Manage host credentials
  vault info                   Show vault backend info
  vault set-encryption-key     Set GPG encryption passphrase
  vault init-age               Initialize age encryption

${BOLD}SCHEDULING & STORAGE:${NC}
  schedule add|remove|list     Manage scheduled backups (launchd/systemd)
  storage upload|download|sync S3/MinIO cloud storage
  storage info                 Show storage configuration
  config init|edit|show|validate  Manage configuration

${BOLD}EXAMPLES:${NC}
  # Setup
  dbx config init              # Create config template
  dbx config edit              # Add your hosts
  dbx vault set production     # Store password securely

  # Enable encryption (optional - GPG or age)
  dbx vault set-encryption-key # Set GPG encryption passphrase
  dbx vault init-age           # Or use age encryption
  # Then set "encryption_type": "gpg" or "age" in config

  # Backup (auto SSH tunnel if configured)
  dbx backup production myapp
  dbx backup staging myapp

  # Verify backup integrity
  dbx verify production/myapp/latest

  # Restore to local container
  dbx restore production/myapp/latest
  dbx restore staging/myapp/latest --name myapp_copy

  # Schedule backups
  dbx schedule add production myapp daily   # Run daily at 2am
  dbx schedule add prod db weekly@0:3       # Sunday at 3am
  dbx schedule list                         # Show scheduled jobs

  # Cloud storage
  dbx storage info                          # Show S3/MinIO config
  dbx storage sync upload production        # Upload all backups for host
  dbx storage list                          # List remote backups

  # Interactive query session
  dbx query production                  # Connect to host
  dbx query production myapp            # Connect to specific database

  # Manage
  dbx list                     # Show all hosts
  dbx list production          # Show databases for host
  dbx clean --keep 5           # Keep only 5 latest per database

${BOLD}CONFIG STRUCTURE:${NC}
  {
    "hosts": { ... },
    "defaults": {
      "encryption_type": "age",   // none, gpg, or age
      "age_recipients": "~/.config/dbx/age-recipients.txt"
    },
    "vault": {
      "backend": "auto"           // keychain, secret-tool, pass, gpg-file
    },
    "notifications": {
      "enabled": true,
      "on": "failure",            // failure, success, all
      "backends": ["slack", "desktop"]
    },
    "storage": {
      "type": "s3",
      "s3": {
        "bucket": "backups",
        "endpoint": "http://minio:9000"
      }
    }
  }

${BOLD}FEATURES:${NC}
  - SSH tunnels: Auto-creates tunnel for remote DBs, cleans up on exit
  - Encryption: GPG or age encryption at rest
  - Checksums: SHA256 verification for backup integrity
  - DEFINER strip: MySQL views/triggers work locally
  - Exclude tables: Dump schema but skip data for large/sensitive tables
  - Credential storage: macOS Keychain, Linux secret-tool, pass, or GPG file
  - Scheduled backups: launchd (macOS) or systemd timers (Linux)
  - Cloud storage: S3/MinIO upload and sync
  - Notifications: Slack, desktop, email on backup success/failure
  - Audit logging: JSON audit trail at ~/.local/share/dbx/audit.log

${BOLD}STORAGE:${NC}
  Backups:  ~/.data/dbx/<host>/<database>/<database>_<timestamp>.sql.zst[.age|.gpg]
  Config:   ~/.config/dbx/config.json
  Audit:    ~/.local/share/dbx/audit.log
  Secrets:  macOS Keychain, Linux secret-tool, pass, or ~/.config/dbx/vault.gpg

${BOLD}REQUIREMENTS:${NC}
  - docker (for pg_dump/mysqldump containers)
  - jq, zstd, ssh
  - gpg or age (optional, for encryption)
  - mc or aws CLI (optional, for S3 storage)
EOF
}

# ============================================================================
# Main
# ============================================================================

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    backup)
      cmd_backup "$@"
      ;;
    restore)
      cmd_restore "$@"
      ;;
    verify)
      cmd_verify "$@"
      ;;
    test|ping)
      cmd_test "$@"
      ;;
    analyze|stats)
      cmd_analyze "$@"
      ;;
    query|q|shell)
      cmd_query "$@"
      ;;
    list|ls)
      cmd_list "$@"
      ;;
    clean|prune)
      cmd_clean "$@"
      ;;
    vault)
      cmd_vault "$@"
      ;;
    config|cfg)
      cmd_config "$@"
      ;;
    schedule|cron)
      cmd_schedule "$@"
      ;;
    storage|s3)
      cmd_storage "$@"
      ;;
    tui|menu)
      cmd_tui
      ;;
    help|--help|-h)
      cmd_help
      ;;
    version|--version|-V)
      echo "dbx $VERSION"
      ;;
    *)
      die "Unknown command: $cmd (run 'dbx help' for usage)"
      ;;
  esac
}

main "$@"
