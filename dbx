#!/usr/bin/env bash
#
# dbx - Database backup and restore utility
# Uses Docker containers for pg_dump/mysqldump (no local install needed)
# Supports SSH tunnels for remote databases (AWS RDS, EC2, etc.)
#
VERSION="0.10.0"
#
# Usage:
#   dbx backup [-v] [--upload] <host> [database]
#   dbx restore <host>/<database>/latest [--name <name>]
#   dbx restore <backup-file> [--name <name>]
#   dbx restore --from-remote <host>/<database>/latest [--name N] [--keep-download]
#   dbx restore s3://<host>/<database>/latest [--name N]
#   dbx test <host>
#   dbx list [host] [database]
#   dbx clean [--keep N] [--dry-run] [--older-than D]
#   dbx verify [backup-file]
#   dbx analyze <host> <database>
#   dbx query <host> [database]
#   dbx config init|edit|show|validate
#   dbx vault set|get|list|delete <host>
#   dbx schedule add|remove|list|run|sync
#   dbx storage upload|download|sync|info
#   dbx scrub init|check|validate <host>/<database>
#

set -euo pipefail

# ============================================================================
# Source library modules
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/core.sh"
source "$LIB_DIR/tunnel.sh"
source "$LIB_DIR/encrypt.sh"
source "$LIB_DIR/postgres.sh"
source "$LIB_DIR/mysql.sh"
source "$LIB_DIR/post_restore.sh"
source "$LIB_DIR/scrub.sh"
source "$LIB_DIR/scrub_strategies.sh"
source "$LIB_DIR/notify.sh"
source "$LIB_DIR/schedule.sh"
source "$LIB_DIR/storage.sh"
source "$LIB_DIR/update.sh"
source "$LIB_DIR/wizard.sh"

# Install the EXIT/INT/TERM cleanup trap. Defined in core.sh but called
# here so that sourcing libs in tests doesn't clobber the test runner's
# own trap.
setup_security_trap

# ============================================================================
# Commands
# ============================================================================

cmd_backup() {
  local host=""
  local database=""
  local verbose=false
  local upload=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -v|--verbose)
        verbose=true
        shift
        ;;
      --upload)
        upload=true
        shift
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -z "$host" ]]; then
          host="$1"
        elif [[ -z "$database" ]]; then
          database="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$host" ]] && die "Usage: dbx backup [-v] [--upload] <host> [database]"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # If no database specified, backup all databases for this host.
  # `|| true` because jq exits non-zero when .databases is missing/null,
  # and we want to fall through to the empty-string check below.
  if [[ -z "$database" ]]; then
    local databases
    databases=$(jq -r ".hosts[\"$host\"].databases | keys[]?" "$CONFIG_FILE" 2>/dev/null || true)
    if [[ -z "$databases" ]]; then
      die "No databases configured for host '$host'. Add them with: dbx config edit"
    fi
    log_step "Backing up all databases for $host"
    local db_errors=0
    while IFS= read -r db; do
      log_info "--- $db ---"
      local backup_args=("$host" "$db")
      [[ "$verbose" == "true" ]] && backup_args+=("-v")
      [[ "$upload" == "true" ]] && backup_args+=("--upload")
      cmd_backup "${backup_args[@]}" || ((db_errors++)) || true
    done <<< "$databases"
    if [[ $db_errors -gt 0 ]]; then
      log_error "$db_errors database(s) failed to backup"
      return 1
    fi
    return 0
  fi

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type
  db_type=$(get_db_type "$host")

  # Create backup directory
  local backup_dir="$DATA_DIR/$host/$database"
  mkdir -p "$backup_dir"

  # Generate filename
  local ts
  ts=$(timestamp)
  local backup_file="$backup_dir/${database}_${ts}.sql.zst"

  local backup_rc=0
  case "$db_type" in
    postgres|postgresql)
      pg_backup "$host" "$database" "$backup_file" "$verbose" || backup_rc=$?
      ;;
    mysql|mariadb)
      mysql_backup "$host" "$database" "$backup_file" "$verbose" || backup_rc=$?
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac

  if [[ $backup_rc -ne 0 ]]; then
    notify_backup_failure "$host" "$database" "Backup process exited with code $backup_rc"
    return $backup_rc
  fi

  echo ""
  log_success "Backup complete: $host/$database"

  # Resolve actual backup file path (may have encryption extension)
  local enc_ext
  enc_ext=$(get_encryption_extension)
  local completed_file="$backup_dir/${database}_${ts}.sql.zst${enc_ext}"

  # Send notification
  local completed_size
  completed_size=$(stat -f%z "$completed_file" 2>/dev/null || stat -c%s "$completed_file" 2>/dev/null || echo "0")
  notify_backup_success "$host" "$database" "$completed_file" "$completed_size"

  # Upload to cloud storage if requested or configured. Per-host
  # `.hosts[$host].auto_upload` overrides the global `.defaults.auto_upload`
  # — both honor the explicit `--upload` flag.
  local auto_upload host_auto_upload
  auto_upload=$(get_config_value ".defaults.auto_upload" 2>/dev/null || echo "")
  host_auto_upload=$(get_config_value ".hosts[\"$host\"].auto_upload" 2>/dev/null || echo "")
  if [[ "$upload" == "true" || "$auto_upload" == "true" || "$host_auto_upload" == "true" ]]; then
    if is_storage_configured; then
      storage_upload "$completed_file" "$host/$database/$(basename "$completed_file")"
    else
      log_warn "Storage not configured. Skipping upload."
    fi
  fi
}

cmd_restore() {
  local source=""
  local target_name=""
  local from_remote=""
  local keep_download=false
  local skip_hooks=false
  local hooks_only=false
  local skip_scrub=false
  local transform_script=""
  local transform_inherit_env=false
  local into_container=""

  # Mixed flag/positional parse: `source` is the only positional and
  # may appear before or after flags (or be absent entirely when the
  # user uses --from-remote).
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name|-n)
        target_name="$2"
        shift 2
        ;;
      --recreate-container)
        export DBX_RECREATE_CONTAINER=true
        shift
        ;;
      --from-remote)
        from_remote="$2"
        shift 2
        ;;
      --keep-download)
        keep_download=true
        shift
        ;;
      --no-post-restore)
        skip_hooks=true
        shift
        ;;
      --hooks-only)
        hooks_only=true
        shift
        ;;
      --no-scrub)
        # Break-glass: bypass the PII scrub gate (debugging only).
        # Loud warning emitted below where the gate would have fired.
        skip_scrub=true
        shift
        ;;
      --transform)
        transform_script="$2"
        shift 2
        ;;
      --transform=*)
        transform_script="${1#--transform=}"
        shift
        ;;
      --transform-inherit-env)
        # Opt-in to passing dbx's full environment (PGPASSWORD, vault
        # tokens, DBX_*) to the transform subprocess. Default since
        # this flag landed is `env -i` with a small allowlist.
        transform_inherit_env=true
        shift
        ;;
      --into)
        into_container="$2"
        shift 2
        ;;
      --into=*)
        into_container="${1#--into=}"
        shift
        ;;
      --*|-*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -z "$source" ]]; then
          source="$1"
        else
          die "Unexpected extra argument: $1"
        fi
        shift
        ;;
    esac
  done

  # `s3://prod/users/latest` URI is shorthand for `--from-remote prod/users/latest`.
  if [[ -z "$from_remote" && "$source" == s3://* ]]; then
    from_remote="${source#s3://}"
    source=""
  fi

  # Flag-combination guards.
  if [[ "$hooks_only" == "true" && "$skip_hooks" == "true" ]]; then
    die "--hooks-only and --no-post-restore are mutually exclusive"
  fi
  if [[ "$hooks_only" == "true" && -n "$from_remote" ]]; then
    die "--hooks-only and --from-remote are mutually exclusive (no backup is fetched in hooks-only mode)"
  fi
  if [[ "$hooks_only" == "true" && (-n "$transform_script" || -n "$into_container") ]]; then
    die "--hooks-only is incompatible with --transform / --into (no engine restore happens in hooks-only mode)"
  fi
  if [[ "$transform_inherit_env" == "true" && -z "$transform_script" ]]; then
    die "--transform-inherit-env requires --transform=PATH"
  fi

  # Validate --transform target is an executable.
  if [[ -n "$transform_script" ]]; then
    if [[ "$transform_script" = /* ]]; then
      [[ -x "$transform_script" ]] || die "--transform: '$transform_script' is not an executable file"
    else
      command -v "$transform_script" >/dev/null 2>&1 || die "--transform: '$transform_script' is not on PATH and is not an absolute executable path"
    fi
  fi

  require_config
  require_jq
  require_docker

  # ---- --hooks-only: run only the configured hooks against an existing DB --
  if [[ "$hooks_only" == "true" ]]; then
    [[ -z "$target_name" ]] && die "--hooks-only requires --name <existing-db>"
    [[ -z "$source" || "$source" != */* ]] && \
      die "--hooks-only requires a <host>/<database> source path so dbx knows which hooks to run"

    local ho_host ho_db ho_dbtype
    ho_host=$(echo "$source" | cut -d'/' -f1)
    ho_db=$(echo "$source" | cut -d'/' -f2)
    [[ -z "$ho_host" || -z "$ho_db" ]] && \
      die "--hooks-only: could not parse host/database from '$source'"

    ho_dbtype=$(get_db_type "$ho_host")
    [[ -z "$ho_dbtype" ]] && die "--hooks-only: host '$ho_host' not found in config (or missing 'type')"

    # --hooks-only is a validation flow — never auto-provision a container.
    local ho_container exists
    case "$ho_dbtype" in
      postgres|postgresql) ho_container="$POSTGRES_CONTAINER" ;;
      mysql|mariadb)       ho_container="$MYSQL_CONTAINER" ;;
      *) die "--hooks-only: unknown database type for host '$ho_host': $ho_dbtype" ;;
    esac
    if ! docker ps -a --format '{{.Names}}' 2>/dev/null | grep -Fxq "$ho_container"; then
      die "--hooks-only: container '$ho_container' does not exist. Run a real restore first to create it."
    fi
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -Fxq "$ho_container"; then
      docker start "$ho_container" >/dev/null || die "--hooks-only: failed to start container '$ho_container'"
    fi
    # count(*) returns "0" or "1" — never empty — so we don't have to
    # distinguish "DB missing" from "query produced no output for some
    # reason". stderr is dropped on purpose; a non-zero exit code from
    # docker/psql/mysql is the only failure signal we care about.
    # Use inline SQL with shell-side quote-doubling. We control $target_name
    # (it comes from --name); psql `-v` substitution was unreliable across
    # versions, so we just escape and interpolate directly.
    local sq=\'
    local esc_name="${target_name//$sq/$sq$sq}"
    case "$ho_dbtype" in
      postgres|postgresql)
        exists=$(docker exec "$ho_container" psql -U postgres -tA \
          -c "SELECT count(*) FROM pg_database WHERE datname = '$esc_name'" 2>/dev/null) \
          || die "--hooks-only: could not query $ho_container (psql failed)"
        [[ "$exists" == "1" ]] || die "--hooks-only: database '$target_name' not found in $ho_container. Restore it first, or pick a different --name."
        ;;
      mysql|mariadb)
        exists=$(docker exec "$ho_container" mysql -u root -NB \
          -e "SELECT count(*) FROM information_schema.schemata WHERE schema_name = '$esc_name'" 2>/dev/null) \
          || die "--hooks-only: could not query $ho_container (mysql failed)"
        [[ "$exists" == "1" ]] || die "--hooks-only: database '$target_name' not found in $ho_container. Restore it first, or pick a different --name."
        ;;
    esac

    log_step "Running post-restore hooks against $target_name (--hooks-only)"
    if ! run_post_restore_hooks "$ho_host" "$ho_db" "$target_name" "$ho_dbtype" \
                                 "$ho_host" "$ho_db" "" ""; then
      die "Post-restore hooks failed against '$target_name'."
    fi
    log_success "Post-restore hooks complete against $target_name"
    return 0
  fi

  # Remote-fetch path: download into a tempdir under $DATA_DIR/.remote/
  # then fall through to the normal local-file restore code below.
  # On success the file is deleted unless --keep-download was passed.
  # On failure we deliberately leave it so the user can retry.
  local remote_local_file=""
  if [[ -n "$from_remote" ]]; then
    if ! is_storage_configured; then
      die "Cloud storage is not configured. Run 'dbx storage info' for setup help."
    fi
    local resolved
    resolved=$(storage_resolve_remote_path "$from_remote") \
      || die "Could not resolve remote backup: $from_remote"
    log_step "Fetching remote backup: $resolved"
    remote_local_file=$(storage_fetch_remote_backup "$resolved") \
      || die "Failed to fetch remote backup: $resolved"
    source="$remote_local_file"
  fi

  local backup_file=""
  local host=""
  local database=""

  # Fuzzy selection if no source provided or just a host
  if [[ -z "$source" ]] || { [[ -n "$source" ]] && [[ ! -f "$source" ]] && [[ "$source" != */* ]]; }; then
    if ! command -v fzf &>/dev/null; then
      die "Usage: dbx restore <host>/<database>/latest [--name <name>]\n       Install fzf for interactive selection"
    fi

    # Build search path
    local search_dir="$DATA_DIR"
    [[ -n "$source" ]] && search_dir="$DATA_DIR/$source"

    if [[ ! -d "$search_dir" ]]; then
      die "No backups found in: $search_dir"
    fi

    # Find all backup files (including encrypted)
    local backups
    backups=$(find "$search_dir" -type f \( -name "*.sql.zst" -o -name "*.sql.gz" -o -name "*.sql" -o -name "*.sql.zst.gpg" -o -name "*.sql.gz.gpg" -o -name "*.sql.zst.age" -o -name "*.sql.gz.age" \) 2>/dev/null | sort -r)

    if [[ -z "$backups" ]]; then
      die "No backup files found in: $search_dir"
    fi

    # Format for fzf: show relative path, size, date
    local formatted
    formatted=$(echo "$backups" | while read -r f; do
      local rel_path="${f#$DATA_DIR/}"
      local size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
      local date=$(ls -l "$f" 2>/dev/null | awk '{print $6, $7, $8}')
      printf "%-60s %8s  %s\n" "$rel_path" "$size" "$date"
    done)

    # Run fzf — pass DATA_DIR via env so the preview shell can quote it,
    # which keeps paths with spaces or shell metacharacters safe.
    local selected
    selected=$(echo "$formatted" | DBX_PREVIEW_DIR="$DATA_DIR" fzf \
      --header="Select backup to restore (ESC to cancel)" \
      --prompt="Restore> " \
      --height=80% \
      --layout=reverse \
      --preview='echo "File: {1}"; echo ""; zstd -dcq "$DBX_PREVIEW_DIR/{1}" 2>/dev/null | head -30 || gzip -dc "$DBX_PREVIEW_DIR/{1}" 2>/dev/null | head -30 || head -30 "$DBX_PREVIEW_DIR/{1}"' \
      --preview-window=right:50%:wrap \
      | awk '{print $1}')

    if [[ -z "$selected" ]]; then
      log_info "Selection cancelled"
      return 0
    fi

    backup_file="$DATA_DIR/$selected"
    # Extract host/database from path
    host=$(echo "$selected" | cut -d'/' -f1)
    database=$(echo "$selected" | cut -d'/' -f2)
  # Parse source - could be path like "production/myapp/latest" or actual file
  elif [[ -f "$source" ]]; then
    backup_file="$source"
    # Try to extract host/database from path
    if [[ "$source" == "$DATA_DIR"/* ]]; then
      local rel_path="${source#$DATA_DIR/}"
      host=$(echo "$rel_path" | cut -d'/' -f1)
      database=$(echo "$rel_path" | cut -d'/' -f2)
    fi
  elif [[ "$source" == */* ]]; then
    # Parse as host/database/selector
    host=$(echo "$source" | cut -d'/' -f1)
    database=$(echo "$source" | cut -d'/' -f2)
    local selector=$(echo "$source" | cut -d'/' -f3)
    selector="${selector:-latest}"

    local backup_dir="$DATA_DIR/$host/$database"
    [[ ! -d "$backup_dir" ]] && die "No backups found for $host/$database"

    if [[ "$selector" == "latest" ]]; then
      # Find latest backup across encrypted/plain. `|| true` keeps the
      # pipeline from failing under set -o pipefail when one of the globs
      # has no matches (ls exits 2 in that case).
      backup_file=$(ls -t "$backup_dir"/*.sql.zst.age "$backup_dir"/*.sql.zst.gpg "$backup_dir"/*.sql.zst 2>/dev/null | head -1 || true)
    else
      backup_file="$backup_dir/$selector"
    fi

    [[ -z "$backup_file" || ! -f "$backup_file" ]] && die "Backup not found: $backup_file"
  else
    die "Invalid source: $source"
  fi

  [[ ! -f "$backup_file" ]] && die "Backup file not found: $backup_file"

  # Determine target database name
  if [[ -z "$target_name" ]]; then
    local base_name="${database:-$(basename "$backup_file")}"
    base_name="${base_name%.sql.zst.age}"
    base_name="${base_name%.sql.zst.gpg}"
    base_name="${base_name%.sql.zst}"
    base_name="${base_name%%_[0-9]*}"  # Remove timestamp suffix
    local date_suffix
    date_suffix=$(date +"%Y%m%d")

    # Find next available version
    local version=1
    while true; do
      target_name="${base_name}_v${version}_${date_suffix}"
      # Check if database exists (try both postgres and mysql)
      if docker exec "$POSTGRES_CONTAINER" psql -U postgres -lqt 2>/dev/null | grep -qw "$target_name"; then
        ((version++))
      elif docker exec "$MYSQL_CONTAINER" mysql -u root -e "SHOW DATABASES" 2>/dev/null | grep -qw "$target_name"; then
        ((version++))
      else
        break
      fi
    done
  fi

  # Determine database type. Try metadata first, then host config, then
  # fall back to content sniffing. Metadata may not include a .type
  # field for older or postgres backups, so an empty result there should
  # fall through rather than terminate the chain.
  local db_type=""
  local meta_file="${backup_file}.meta.json"
  [[ -f "$meta_file" ]] && db_type=$(jq -r '.type // empty' "$meta_file")
  [[ -z "$db_type" && -n "$host" ]] && db_type=$(get_db_type "$host")
  if [[ -z "$db_type" ]]; then
    if decompress_backup "$backup_file" | head -c 100 | grep -q "PostgreSQL"; then
      db_type="postgres"
    else
      db_type="mysql"
    fi
  fi

  log_info "Restoring: $(basename "$backup_file")"
  log_info "Target database: $target_name"

  local restore_start
  restore_start=$(date +%s)

  # Pre-restore PII scrub drift check. Reads schema captured in the
  # backup's meta.json (added at backup time) and diffs against the
  # host's manifest. On drift: abort BEFORE the engine restore so no
  # data ever lands in the local container. Older backups (no
  # captured schema) fall through and get checked by the post-restore
  # gate. Bypassed by --no-scrub or when no gate is configured.
  if [[ "$skip_scrub" == "false" && -n "$host" ]] && scrub_gate_active "$host"; then
    local pre_meta="${backup_file}.meta.json"
    [[ ! -f "$pre_meta" ]] && pre_meta="${backup_file%.zst}.meta.json"
    [[ ! -f "$pre_meta" ]] && pre_meta="${backup_file%.age}.meta.json"
    [[ ! -f "$pre_meta" ]] && pre_meta="${backup_file%.gpg}.meta.json"
    # Suppress set -e so we can branch on the specific exit code; the
    # preflight returns 2 specifically for drift (vs 1 for error / 0
    # for clean-or-legacy-backup).
    local pre_rc=0
    scrub_preflight_drift_check "$host" "$pre_meta" || pre_rc=$?
    if [[ "$pre_rc" -eq 2 ]]; then
      audit_restore "$backup_file" "$target_name" "failure" 0
      notify_restore_failure "$backup_file" "$target_name" "scrub preflight drift check failed"
      die "scrub: pre-restore drift check failed. No data was restored."
    fi
  fi

  # --transform / --into take the streaming code path. --into is
  # postgres-only; MySQL --into is rejected below.
  if [[ -n "$transform_script" || -n "$into_container" ]]; then
    local target_container="" target_user="postgres" target_pass=""
    if [[ -n "$into_container" ]]; then
      case "$db_type" in
        postgres|postgresql) ;;
        mysql|mariadb) die "--into is only supported for postgres restores (got db_type=$db_type)" ;;
        *) die "--into: unsupported db_type '$db_type'" ;;
      esac
      local resolved
      resolved=$(pg_resolve_into_container "$into_container")
      target_container=$(printf '%s' "$resolved" | cut -f1)
      target_user=$(printf '%s' "$resolved" | cut -f2)
      target_pass=$(printf '%s' "$resolved" | cut -f3)
      log_info "Resolved --into container: $target_container (user=$target_user)"
      log_warn "================================================================"
      log_warn "  --into: PII scrub gate BYPASSED for external container '$into_container'."
      log_warn "  dbx cannot safely DROP a user-managed container's DB on failure,"
      log_warn "  so the scrub gate does not run. The --transform script (if set)"
      log_warn "  is the only sanitization layer. Operator owns correctness."
      log_warn "================================================================"
      # Ad-hoc file restores (no host/db parsed from source) get a
      # distinct audit tag — `scrub_bypass into_external` implies the
      # gate would have run absent --into, which only applies when a
      # gated host is in play. Empty host/db kv pairs are skipped to
      # keep the audit grep-friendly.
      if [[ -n "$host" && -n "$database" ]]; then
        audit_log "scrub_bypass" "into_external" \
          "host" "$host" "database" "$database" "into_container" "$into_container"
      else
        audit_log "restore_into" "adhoc_file" \
          "backup_file" "$(basename "$backup_file")" "into_container" "$into_container"
      fi
    fi
    case "$db_type" in
      postgres|postgresql)
        [[ -z "$target_container" ]] && target_container="$POSTGRES_CONTAINER"
        pg_restore_backup_streaming "$backup_file" "$target_name" \
          "$target_container" "$target_user" "$target_pass" \
          "$transform_script" "$transform_inherit_env"
        ;;
      mysql|mariadb)
        # MySQL --transform path (--into already rejected above).
        mysql_restore_backup_streaming "$backup_file" "$target_name" \
          "$transform_script" "$transform_inherit_env"
        ;;
      *)
        die "Unknown database type: $db_type"
        ;;
    esac
  else
    case "$db_type" in
      postgres|postgresql)
        pg_restore_backup "$backup_file" "$target_name"
        ;;
      mysql|mariadb)
        mysql_restore_backup "$backup_file" "$target_name"
        ;;
      *)
        die "Unknown database type: $db_type"
        ;;
    esac
  fi

  # Hooks skipped for ad-hoc file restores (no host/db in path).
  # Hooks also skipped when --into targets an external container: the
  # hook runners (pg_run_sql_stream / mysql_run_sql_stream) hardcode the
  # local POSTGRES_CONTAINER / MYSQL_CONTAINER, so running them after an
  # --into restore would mutate the wrong DB. The operator uses
  # --transform for sanitization in the --into flow.
  if [[ "$skip_hooks" == "false" && -n "$host" && -n "$database" && -z "$into_container" ]]; then
    local backup_basename backup_ts
    backup_basename=$(basename "$backup_file")
    backup_ts=$(parse_backup_timestamp "$backup_basename")
    if ! run_post_restore_hooks "$host" "$database" "$target_name" "$db_type" \
                                 "$host" "$database" "$backup_basename" "$backup_ts"; then
      local fail_dur=$(($(date +%s) - restore_start))
      audit_restore "$backup_file" "$target_name" "failure" "$fail_dur"
      notify_restore_failure "$backup_file" "$target_name" "post-restore hooks failed"
      die "Post-restore hooks failed. Database '$target_name' is in a partial state and was left in place for inspection."
    fi
  elif [[ "$skip_hooks" == "false" && -n "$into_container" ]]; then
    log_warn "--into: post-restore hooks are skipped (hook runners target the managed postgres-dbx container, not '$into_container')."
  elif [[ "$skip_hooks" == "false" && -z "$host" ]]; then
    # Ad-hoc file restore: tell the user explicitly that any configured
    # hooks won't run, so they don't assume PII scrub / config rewrites
    # already happened.
    log_warn "Ad-hoc file restore: any configured post_restore hooks are skipped (no host/db context in the source path)."
  fi

  # PII scrub gate. Fires when hosts.<host>.scrub.required is true. The
  # gate is fail-closed: any drift / UPDATE error / sniff failure drops
  # the target DB rather than leaving it for inspection (a half-scrubbed
  # clone is more dangerous than no clone).
  #
  # When --into <container> is set we ALREADY bypassed the gate above
  # (with audit log) — see the streaming dispatch block. Skip the gate
  # block entirely in that case so we don't double-log.
  if [[ -n "$host" && -n "$database" && -z "$into_container" ]]; then
    if scrub_gate_active "$host"; then
      if [[ "$skip_scrub" == "true" ]]; then
        log_warn "================================================================"
        log_warn "  --no-scrub: PII scrub gate BYPASSED for $host/$database"
        log_warn "  The restored DB '$target_name' contains UNSCRUBBED prod data."
        log_warn "  Do NOT hand this clone to anyone. Drop it when done debugging."
        log_warn "================================================================"
        # Separate audit entry so compliance review can grep `scrub_bypass`.
        # The default audit_restore("success") line still records the restore
        # itself; this row is the marker that the gate did not run.
        audit_log "scrub_bypass" "bypassed" \
          "host" "$host" "database" "$database" "target" "$target_name"
      else
        local scrub_report_dir="$DATA_DIR/$host/$database"
        if ! scrub_run_gate "$host" "$database" "$target_name" "$db_type" "$scrub_report_dir"; then
          local fail_dur=$(($(date +%s) - restore_start))
          audit_restore "$backup_file" "$target_name" "failure" "$fail_dur"
          notify_restore_failure "$backup_file" "$target_name" "scrub gate failed (target DB dropped)"
          die "Scrub gate FAILED. Target DB '$target_name' was DROPPED (fail-closed). See scrub_report.json under $scrub_report_dir."
        fi
      fi
    elif [[ "$skip_scrub" == "true" ]]; then
      # --no-scrub was passed but no gate would have fired anyway. Be
      # explicit so the user doesn't think they bypassed a real check.
      log_info "--no-scrub: no scrub gate is configured for $host (flag had no effect)."
    fi
  fi

  local restore_dur=$(($(date +%s) - restore_start))
  audit_restore "$backup_file" "$target_name" "success" "$restore_dur"

  echo ""
  log_success "Database restored as: $target_name"
  notify_restore_success "$backup_file" "$target_name"

  # Clean up the downloaded file from --from-remote unless the user
  # asked to keep it. Only reached on a successful restore — failure
  # paths above all `die`, so the temp file is preserved for retry.
  if [[ -n "$remote_local_file" && "$keep_download" != "true" ]]; then
    local meta="${remote_local_file}.meta.json"
    local parent_dir
    parent_dir=$(dirname "$remote_local_file")
    rm -f "$remote_local_file" "$meta"
    # Remove the mktemp dir if it's now empty (it's under $DATA_DIR/.remote/dl.XXXXXX).
    rmdir "$parent_dir" 2>/dev/null || true
  elif [[ -n "$remote_local_file" && "$keep_download" == "true" ]]; then
    log_info "Downloaded backup kept at: $remote_local_file"
  fi
}

cmd_list() {
  local host="${1:-}"
  local database="${2:-}"

  require_jq

  if [[ -n "$host" && -n "$database" ]]; then
    # List backups for specific host/database
    local backup_dir="$DATA_DIR/$host/$database"
    if [[ ! -d "$backup_dir" ]]; then
      log_warn "No backups found for $host/$database"
      return
    fi

    echo -e "${BOLD}Backups for $host/$database:${NC}"
    echo ""
    printf "%-40s %10s %12s\n" "FILENAME" "SIZE" "DATE"
    printf "%-40s %10s %12s\n" "--------" "----" "----"

    for meta in "$backup_dir"/*.meta.json; do
      [[ ! -f "$meta" ]] && continue
      local filename size_bytes size_human timestamp
      filename=$(basename "${meta%.meta.json}")
      size_bytes=$(jq -r '.size // 0' "$meta")
      size_human=$(human_size "$size_bytes")
      timestamp=$(jq -r '.timestamp // "" | split("T")[0]' "$meta")
      printf "%-40s %10s %12s\n" "$filename" "$size_human" "$timestamp"
    done
  elif [[ -n "$host" ]]; then
    # List databases for host
    local host_dir="$DATA_DIR/$host"
    if [[ ! -d "$host_dir" ]]; then
      log_warn "No backups found for host: $host"
      return
    fi

    echo -e "${BOLD}Databases with backups on $host:${NC}"
    for db_dir in "$host_dir"/*/; do
      [[ -d "$db_dir" ]] && echo "  $(basename "$db_dir")"
    done
  else
    # List all hosts
    if [[ ! -d "$DATA_DIR" ]]; then
      log_warn "No backups found"
      return
    fi

    echo -e "${BOLD}Available backup hosts:${NC}"
    for host_dir in "$DATA_DIR"/*/; do
      if [[ -d "$host_dir" ]]; then
        local h=$(basename "$host_dir")
        local count=$(find "$host_dir" \( -name "*.sql.zst" -o -name "*.sql.zst.gpg" -o -name "*.sql.zst.age" \) 2>/dev/null | wc -l | tr -d ' ')
        echo "  $h ($count backups)"
      fi
    done
  fi
}

cmd_clean() {
  local keep
  keep=$(get_config_value ".defaults.keep_backups" 2>/dev/null || echo "10")
  [[ -z "$keep" || "$keep" == "null" ]] && keep=10
  local dry_run=false
  local older_than_days=""
  local keep_explicit=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep|-k)
        keep="$2"
        keep_explicit=true
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      --older-than)
        older_than_days="$2"
        shift 2
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        shift
        ;;
    esac
  done

  # In age-based mode, the default --keep value is advisory — it
  # would otherwise turn `dbx clean --older-than D` into a no-op
  # whenever the backup count happens to be below the default floor
  # (#22). Explicit --keep is still honored as a floor.
  local effective_keep=$keep
  if [[ -n "$older_than_days" && "$keep_explicit" == "false" ]]; then
    effective_keep=0
  fi

  [[ "$dry_run" == "true" ]] && log_info "[DRY RUN] No files will be deleted"
  if [[ -n "$older_than_days" ]]; then
    log_step "Cleaning backups older than ${older_than_days}d (keeping newest $effective_keep per database)"
  else
    log_step "Cleaning old backups (keeping $effective_keep per database)"
  fi

  local total_removed=0
  local total_freed=0

  for host_dir in "$DATA_DIR"/*/; do
    [[ ! -d "$host_dir" ]] && continue
    for db_dir in "$host_dir"/*/; do
      [[ ! -d "$db_dir" ]] && continue

      local backups=()
      while IFS= read -r f; do
        [[ -n "$f" ]] && backups+=("$f")
      done < <(ls -t "$db_dir"/*.sql.zst.age "$db_dir"/*.sql.zst.gpg "$db_dir"/*.sql.zst 2>/dev/null)

      # The two retention modes are mutually exclusive. --older-than
      # used to run after count-based retention had already deleted
      # backups[$keep:], leaving it with nothing to act on (#22).
      if [[ -n "$older_than_days" ]]; then
        local idx=0
        for backup in "${backups[@]}"; do
          ((idx++)) || true
          # Preserve the newest $effective_keep backups regardless of age.
          [[ $idx -le $effective_keep ]] && continue
          local file_age_days
          if is_macos; then
            file_age_days=$(( ($(date +%s) - $(stat -f%m "$backup")) / 86400 ))
          else
            file_age_days=$(( ($(date +%s) - $(stat -c%Y "$backup")) / 86400 ))
          fi
          if [[ $file_age_days -gt $older_than_days ]]; then
            local size meta_file
            size=$(stat -f%z "$backup" 2>/dev/null || stat -c%s "$backup")
            total_freed=$((total_freed + size))
            meta_file="${backup}.meta.json"
            if [[ "$dry_run" == "true" ]]; then
              log_info "Would remove (${file_age_days}d old): $(basename "$backup")"
            else
              rm -f "$backup" "$meta_file"
              log_info "Removed (${file_age_days}d old): $(basename "$backup")"
            fi
            ((total_removed++)) || true
          fi
        done
      elif [[ ${#backups[@]} -gt $effective_keep ]]; then
        local to_remove=("${backups[@]:$effective_keep}")
        for backup in "${to_remove[@]}"; do
          local size meta_file
          size=$(stat -f%z "$backup" 2>/dev/null || stat -c%s "$backup")
          total_freed=$((total_freed + size))
          # Metadata is written at "<backup_filename>.meta.json" regardless
          # of encryption suffix (see pg_backup / mysql_backup).
          meta_file="${backup}.meta.json"
          if [[ "$dry_run" == "true" ]]; then
            log_info "Would remove: $(basename "$backup")"
          else
            rm -f "$backup" "$meta_file"
            log_info "Removed: $(basename "$backup")"
          fi
          ((total_removed++)) || true
        done
      fi
    done
  done

  if [[ $total_removed -gt 0 ]]; then
    if [[ "$dry_run" == "true" ]]; then
      log_info "Would remove $total_removed backups, freeing $(human_size $total_freed)"
    else
      log_success "Removed $total_removed backups, freed $(human_size $total_freed)"
    fi
  else
    log_info "No old backups to remove"
  fi
}

cmd_vault() {
  local action="${1:-}"
  local host="${2:-}"

  case "$action" in
    set)
      [[ -z "$host" ]] && die "Usage: dbx vault set <host>"

      require_config
      require_jq

      # Get host info from config
      local db_host db_port db_user db_type
      db_type=$(get_config_value ".hosts[\"$host\"].type")
      db_host=$(get_config_value ".hosts[\"$host\"].host")
      db_port=$(get_config_value ".hosts[\"$host\"].port")
      db_user=$(get_config_value ".hosts[\"$host\"].user")

      [[ -z "$db_type" ]] && die "Host '$host' not found in config. Run: dbx config edit"

      echo -e "${BOLD}Setting credentials for: $host${NC}"
      echo "  Type: $db_type"
      echo "  Host: $db_host:$db_port"
      echo "  User: $db_user"
      echo ""

      # Prompt for password
      echo -n "Password: "
      read -rs password
      echo ""

      if [[ -z "$password" ]]; then
        die "Password cannot be empty"
      fi

      # Store in keychain
      keychain_set "$host" "$password"
      audit_vault "set" "$host" "success"
      log_success "Credentials stored for: $host"
      log_info "Password will be retrieved automatically during backup"
      ;;

    get)
      [[ -z "$host" ]] && die "Usage: dbx vault get <host>"
      local pass
      pass=$(keychain_get "$host" 2>/dev/null || true)
      if [[ -n "$pass" ]]; then
        echo "$pass"
      else
        die "No credentials found for: $host"
      fi
      ;;

    delete|rm)
      [[ -z "$host" ]] && die "Usage: dbx vault delete <host>"
      if keychain_delete "$host"; then
        log_success "Credentials removed for: $host"
        audit_vault "delete" "$host" "success"
      else
        log_warn "No credentials found for: $host"
      fi
      ;;

    list|ls)
      echo -e "${BOLD}Stored credentials:${NC}"
      local hosts
      hosts=$(keychain_list)
      if [[ -n "$hosts" ]]; then
        echo "$hosts" | while read -r h; do
          [[ "$h" == "_dbx_encryption_key" ]] && continue
          echo "  $h"
        done
      else
        echo "  (none)"
      fi
      # Check encryption key
      if get_encryption_key &>/dev/null; then
        echo ""
        echo -e "${BOLD}Encryption:${NC}"
        echo "  Key is set"
      fi
      ;;

    set-encryption-key)
      echo -e "${BOLD}Setting encryption key for backups${NC}"
      echo ""
      echo "This passphrase will be used to encrypt all backups."
      echo "Store it safely - you cannot recover backups without it!"
      echo ""

      echo -n "Encryption passphrase: "
      read -rs passphrase
      echo ""

      if [[ -z "$passphrase" ]]; then
        die "Passphrase cannot be empty"
      fi

      echo -n "Confirm passphrase: "
      read -rs passphrase_confirm
      echo ""

      if [[ "$passphrase" != "$passphrase_confirm" ]]; then
        die "Passphrases do not match"
      fi

      set_encryption_key "$passphrase"
      audit_vault "set" "encryption_key" "success"
      log_success "Encryption key stored"
      log_info "Enable encryption in config: dbx config edit"
      log_info "Set \"encryption\": true in defaults section"
      ;;

    delete-encryption-key)
      if delete_encryption_key; then
        log_success "Encryption key removed"
      else
        log_warn "No encryption key found"
      fi
      ;;

    info)
      vault_info
      ;;

    init-age|init-encryption)
      require_age
      init_age_encryption
      ;;

    *)
      die "Usage: dbx vault <set|get|delete|list|info|set-encryption-key|init-age> [host]"
      ;;
  esac
}

cmd_config() {
  local action="${1:-show}"

  case "$action" in
    init)
      mkdir -p "$CONFIG_DIR"
      if [[ -f "$CONFIG_FILE" ]]; then
        log_warn "Config already exists: $CONFIG_FILE"
        return
      fi

      cat > "$CONFIG_FILE" <<'EOF'
{
  "hosts": {
    "example-mysql": {
      "type": "mysql",
      "user": "backup_user",
      "definer_handling": "strip",
      "ssh_tunnel": {
        "jump_host": "bastion-server",
        "target_host": "mysql.internal",
        "target_port": 3306
      },
      "databases": {
        "myapp": {
          "exclude_data": ["sessions", "cache", "jobs"]
        }
      }
    },
    "example-rds": {
      "type": "mysql",
      "user": "admin",
      "definer_handling": "strip",
      "ssh_tunnel": {
        "jump_host": "bastion",
        "target_host": "mydb.xxxx.us-east-1.rds.amazonaws.com",
        "target_port": 3306
      },
      "databases": {
        "production": {
          "exclude_data": ["audit_logs", "sessions"]
        }
      }
    },
    "local": {
      "type": "postgres",
      "host": "localhost",
      "port": 5432,
      "user": "postgres",
      "databases": {
        "devdb": {}
      }
    }
  },
  "defaults": {
    "compression": "zstd",
    "compression_level": 3,
    "parallel_jobs": 4,
    "keep_backups": 10,
    "definer_handling": "strip",
    "encryption": false
  }
}
EOF
      log_success "Config created: $CONFIG_FILE"
      secure_file "$CONFIG_FILE"
      log_info "Edit it with: dbx config edit"
      log_info "Store passwords with: dbx vault set <host>"
      ;;

    edit)
      require_config
      "${EDITOR:-vim}" "$CONFIG_FILE"
      # Validate JSON after editing
      if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        log_error "Config file contains invalid JSON!"
        log_warn "Fix it with: dbx config edit"
      else
        log_success "Config is valid JSON"
      fi
      ;;

    show)
      require_config
      require_jq
      jq '.' "$CONFIG_FILE"
      ;;

    validate)
      require_config
      require_jq

      local errors=0

      # Check valid JSON
      if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        log_error "Config file is not valid JSON"
        return 1
      fi
      log_success "Valid JSON"

      # Check hosts exist
      local host_count
      host_count=$(jq '.hosts | length' "$CONFIG_FILE")
      if [[ "$host_count" -eq 0 ]]; then
        log_warn "No hosts configured"
      else
        log_success "$host_count host(s) configured"
      fi

      # Validate each host
      local hosts
      hosts=$(jq -r '.hosts | keys[]' "$CONFIG_FILE")
      while IFS= read -r h; do
        local htype huser
        htype=$(jq -r ".hosts[\"$h\"].type // empty" "$CONFIG_FILE")
        huser=$(jq -r ".hosts[\"$h\"].user // empty" "$CONFIG_FILE")

        if [[ -z "$htype" ]]; then
          log_error "Host '$h': missing 'type' (postgres or mysql)"
          ((errors++)) || true
        elif [[ "$htype" != "postgres" && "$htype" != "postgresql" && "$htype" != "mysql" && "$htype" != "mariadb" ]]; then
          log_error "Host '$h': invalid type '$htype' (use postgres or mysql)"
          ((errors++)) || true
        fi

        if [[ -z "$huser" ]]; then
          log_error "Host '$h': missing 'user'"
          ((errors++)) || true
        fi

        # Check if a password source exists (without invoking external commands)
        local has_vault has_cmd has_plain
        has_vault=$(keychain_get "$h" 2>/dev/null || true)
        has_cmd=$(get_config_value ".hosts[\"$h\"].password_cmd" 2>/dev/null || true)
        has_plain=$(get_config_value ".hosts[\"$h\"].password" 2>/dev/null || true)
        if [[ -z "$has_vault" && -z "$has_cmd" && -z "$has_plain" ]]; then
          log_warn "Host '$h': no password source found (vault, password_cmd, or config)"
        fi
      done <<< "$hosts"

      # Validate post_restore hook entries (host-level and per-DB). Catches
      # broken file paths and malformed entries before a 2am scheduled run
      # would hit them.
      local cfg_dir
      cfg_dir=$(dirname "$CONFIG_FILE")
      while IFS= read -r h; do
        local hlen
        hlen=$(jq ".hosts[\"$h\"].post_restore // [] | length" "$CONFIG_FILE")
        local i=0
        while [[ "$i" -lt "$hlen" ]]; do
          validate_hook_entry "$h" "" "$i" "host" "$cfg_dir" || ((errors++)) || true
          i=$((i + 1))
        done
        local dbs
        dbs=$(jq -r ".hosts[\"$h\"].databases | keys[]?" "$CONFIG_FILE" 2>/dev/null || true)
        if [[ -n "$dbs" ]]; then
          while IFS= read -r d; do
            local dlen
            dlen=$(jq ".hosts[\"$h\"].databases[\"$d\"].post_restore // [] | length" "$CONFIG_FILE")
            local j=0
            while [[ "$j" -lt "$dlen" ]]; do
              validate_hook_entry "$h" "$d" "$j" "db" "$cfg_dir" || ((errors++)) || true
              j=$((j + 1))
            done
          done <<< "$dbs"
        fi
      done <<< "$hosts"

      # Validate any scrub manifests referenced from host configs. A
      # broken manifest causes `dbx scrub check` and the restore-time
      # gate to fail, so catch it during `dbx config validate` rather
      # than at 2am when a scheduled job tries to use it.
      while IFS= read -r h; do
        [[ -z "$h" ]] && continue
        local mf
        mf=$(scrub_manifest_path "$h")
        if [[ -n "$mf" ]]; then
          if [[ ! -f "$mf" ]]; then
            log_error "Host '$h': scrub.manifest references missing file: $mf"
            ((errors++)) || true
          else
            if scrub_validate_manifest "$mf" >/dev/null 2>&1; then
              log_success "Host '$h': scrub manifest valid ($(basename "$mf"))"
            else
              # Re-run with full output so the user sees each error.
              log_error "Host '$h': scrub manifest INVALID ($mf):"
              scrub_validate_manifest "$mf" || true
              ((errors++)) || true
            fi
            # If scrub.required is true, require the seed_env to be set
            # in the current environment (warn-only — required env vars
            # may legitimately be missing in interactive use).
            local req
            req=$(jq -r ".hosts[\"$h\"].scrub.required // false" "$CONFIG_FILE")
            if [[ "$req" == "true" ]]; then
              local seed_env_name
              seed_env_name=$(jq -r '.seed_env // empty' "$mf" 2>/dev/null || true)
              if [[ -n "$seed_env_name" ]] && [[ -z "${!seed_env_name:-}" ]]; then
                log_warn "Host '$h': scrub.required=true and seed_env '$seed_env_name' is unset in current env"
              fi
            fi
          fi
        fi
      done <<< "$hosts"

      # Check encryption config coherence
      local enc_type
      enc_type=$(get_encryption_type 2>/dev/null || echo "none")
      if [[ "$enc_type" == "age" ]]; then
        local recipients
        recipients=$(get_age_recipients_file)
        if [[ ! -f "$recipients" ]]; then
          log_error "Encryption type 'age' but recipients file missing: $recipients"
          log_info "Run: dbx vault init-age"
          ((errors++)) || true
        else
          log_success "Age encryption configured"
        fi
      elif [[ "$enc_type" == "gpg" ]]; then
        if ! get_encryption_key &>/dev/null; then
          log_error "Encryption type 'gpg' but no encryption key set"
          log_info "Run: dbx vault set-encryption-key"
          ((errors++)) || true
        else
          log_success "GPG encryption configured"
        fi
      fi

      # Schedule drift warning (#39). Doesn't count as a validation error
      # — config.schedules and installed units are two separate sources
      # of truth in v0.x. Reports drift as a hint to run `schedule sync`.
      local cfg_sched
      cfg_sched=$(jq -r '.schedules // [] | length' "$CONFIG_FILE" 2>/dev/null || echo 0)
      if [[ "$cfg_sched" -gt 0 ]]; then
        local cfg_tsv inst_tsv plan actionable
        cfg_tsv=$(schedule_config_read || true)
        inst_tsv=$(schedule_installed_read || true)
        plan=$(schedule_sync_plan "$cfg_tsv" "$inst_tsv")
        actionable=$(echo "$plan" | grep -cE '^(install|update|orphan)' 2>/dev/null || echo 0)
        if [[ "$actionable" -gt 0 ]]; then
          log_warn "config.schedules has $actionable change(s) not reflected in installed units. Run 'dbx schedule sync' to preview."
        else
          log_success "$cfg_sched schedule(s) configured, in sync with installed units"
        fi
      fi

      if [[ $errors -gt 0 ]]; then
        echo ""
        log_error "$errors error(s) found"
        return 1
      else
        echo ""
        log_success "Config validation passed"
      fi
      ;;

    *)
      die "Unknown config action: $action (use: init, edit, show, validate)"
      ;;
  esac
}

cmd_analyze() {
  local host="${1:-}"
  local database="${2:-}"

  [[ -z "$host" ]] && die "Usage: dbx analyze <host> <database>"
  [[ -z "$database" ]] && die "Usage: dbx analyze <host> <database>"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type
  db_type=$(get_db_type "$host")

  case "$db_type" in
    mysql|mariadb)
      analyze_mysql "$host" "$database"
      ;;
    postgres|postgresql)
      analyze_postgres "$host" "$database"
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac
}

cmd_verify() {
  local backup_file="${1:-}"

  if [[ -z "$backup_file" ]]; then
    # Interactive selection
    if command -v fzf &>/dev/null && [[ -d "$DATA_DIR" ]]; then
      local backups
      backups=$(find "$DATA_DIR" -type f \( -name "*.sql.zst" -o -name "*.sql.zst.gpg" -o -name "*.sql.zst.age" \) 2>/dev/null | sort -r)

      if [[ -n "$backups" ]]; then
        local formatted
        formatted=$(echo "$backups" | while read -r f; do
          local rel size
          rel="${f#$DATA_DIR/}"
          size=$(ls -lh "$f" 2>/dev/null | awk '{print $5}')
          printf "%-60s %8s\n" "$rel" "$size"
        done)

        local selected
        selected=$(echo "$formatted" | fzf --header="Select backup to verify:" --prompt="Verify> " | awk '{print $1}')
        [[ -z "$selected" ]] && return 0
        backup_file="$DATA_DIR/$selected"
      fi
    fi
  fi

  [[ -z "$backup_file" ]] && die "Usage: dbx verify <backup-file>"
  [[ ! -f "$backup_file" ]] && die "File not found: $backup_file"

  require_jq

  verify_backup "$backup_file"
}

cmd_schedule() {
  local action="${1:-list}"
  shift || true

  case "$action" in
    add)
      local host="${1:-}"
      local database="${2:-}"
      local schedule="${3:-daily}"

      [[ -z "$host" ]] && die "Usage: dbx schedule add <host> <database> [schedule]"
      [[ -z "$database" ]] && die "Usage: dbx schedule add <host> <database> [schedule]"

      require_config
      schedule_add "$host" "$database" "$schedule"
      ;;

    remove|rm|delete)
      local host="${1:-}"
      local database="${2:-}"

      [[ -z "$host" ]] && die "Usage: dbx schedule remove <host> <database>"
      [[ -z "$database" ]] && die "Usage: dbx schedule remove <host> <database>"

      schedule_remove "$host" "$database"
      ;;

    run)
      local host="${1:-}"
      local database="${2:-}"

      [[ -z "$host" ]] && die "Usage: dbx schedule run <host> <database>"
      [[ -z "$database" ]] && die "Usage: dbx schedule run <host> <database>"

      schedule_run "$host" "$database"
      ;;

    list|ls|"")
      schedule_list
      ;;

    sync)
      # Reconcile config.schedules[] against installed units. Read-only
      # in this slice (#39 PR A): always behaves as --dry-run. The write
      # path lands in a follow-up PR. Lets users validate their config
      # block today before committing to the full declarative flow.
      require_config
      require_jq
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --dry-run) shift ;;
          --force)   die "--force is not yet implemented (write path lands in a follow-up PR; only --dry-run is supported today)" ;;
          -*)        die "Unknown schedule sync option: $1" ;;
          *)         die "Unknown schedule sync argument: $1" ;;
        esac
      done

      local cfg_tsv inst_tsv plan
      cfg_tsv=$(schedule_config_read || true)
      inst_tsv=$(schedule_installed_read || true)
      plan=$(schedule_sync_plan "$cfg_tsv" "$inst_tsv")

      schedule_sync_print_plan "$plan"
      local plan_rc=$?
      echo "  (read-only preview — the write path lands in a follow-up PR)"
      # Non-zero exit when there's actionable drift so CI / pre-commit
      # hooks can use this as a check.
      return "$plan_rc"
      ;;

    *)
      die "Unknown schedule action: $action (use: add, remove, list, run, sync)"
      ;;
  esac
}

# Atomically write the .storage.s3 block to $CONFIG_FILE.
# Args: provider ("AWS S3"|"S3-compatible"), endpoint, region, bucket, prefix, access_key
storage_write_block() {
  local provider="$1" endpoint="$2" region="$3" bucket="$4" prefix="$5" access_key="$6"
  local tmp; tmp=$(mktemp)
  jq --arg ep "$endpoint" --arg rg "$region" --arg bk "$bucket" \
     --arg px "$prefix" --arg ak "$access_key" \
     '.storage = {type: "s3", s3: ({endpoint: $ep, region: $rg, bucket: $bk, prefix: $px, access_key: $ak} | with_entries(select(.value != "")))}' \
     "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  secure_file "$CONFIG_FILE"
}

# Delete the .storage block. Used by the rollback path.
storage_delete_block() {
  local tmp; tmp=$(mktemp)
  jq 'del(.storage)' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  secure_file "$CONFIG_FILE"
}

storage_add() {
  require_config
  require_jq
  require_gum
  require_s3_client
  # If storage is already configured, ask whether to replace.
  if is_storage_configured; then
    local existing
    existing=$(get_config_value ".storage.s3.endpoint" 2>/dev/null || echo "AWS S3")
    if ! gum confirm --default=false "Storage is already configured (${existing}). Replace?"; then
      log_info "Keeping existing storage config."
      return 0
    fi
  fi

  # Provider branch
  local provider endpoint region bucket prefix
  provider=$(gum choose --header "Storage provider:" \
    "AWS S3" "S3-compatible (MinIO, R2, B2, ...)")
  [[ -z "$provider" ]] && { log_info "Aborted."; return 0; }

  if [[ "$provider" == "AWS S3" ]]; then
    # Canonical AWS endpoint. mc requires a non-empty endpoint; aws_get_endpoint_arg
    # (lib/storage.sh) skips --endpoint-url when it sees exactly this value, so
    # the aws path still uses its built-in regional resolution.
    endpoint="https://s3.amazonaws.com"
    region=$(gum input --header "AWS region:" --placeholder "us-east-1")
    [[ -z "$region" ]] && { log_info "Aborted."; return 0; }
  else
    endpoint=$(gum input --header "Endpoint URL:" --placeholder "https://minio.example.com")
    [[ -z "$endpoint" ]] && { log_info "Aborted."; return 0; }
    region=$(gum input --header "Region (optional, blank to skip):")
    # blank region OK for S3-compatible
  fi

  bucket=$(gum input --header "Bucket:" --placeholder "backups")
  [[ -z "$bucket" ]] && { log_info "Aborted."; return 0; }

  prefix=$(gum input --header "Prefix / path (blank for bucket root):")
  # blank prefix OK

  local access_key
  access_key=$(gum input --header "Access key:" --placeholder "AKIA…")
  [[ -z "$access_key" ]] && { log_info "Aborted."; return 0; }

  # Vault may already contain a secret from a prior run.
  local existing_secret
  existing_secret=$(keychain_get "s3-secret-key" 2>/dev/null || true)
  if [[ -n "$existing_secret" ]]; then
    local secret_choice
    secret_choice=$(gum choose --header "Vault already has an S3 secret key." \
                               "Use existing" "Replace")
    [[ -z "$secret_choice" ]] && { log_info "Aborted."; return 0; }
    if [[ "$secret_choice" == "Replace" ]]; then
      local new_secret
      new_secret=$(gum input --password --header "New S3 secret key:")
      [[ -z "$new_secret" ]] && { log_info "Aborted."; return 0; }
      keychain_set "s3-secret-key" "$new_secret"
    fi
  else
    local new_secret
    new_secret=$(gum input --password --header "S3 secret key:")
    [[ -z "$new_secret" ]] && { log_info "Aborted."; return 0; }
    keychain_set "s3-secret-key" "$new_secret"
  fi

  while :; do
    log_step "Writing provisional storage config and running round-trip test..."
    storage_write_block "$provider" "$endpoint" "$region" "$bucket" "$prefix" "$access_key"

    if storage_test_roundtrip; then
      log_success "Storage validated."
      break
    fi

    log_error "Storage validation failed."
    local recover
    recover=$(gum choose --header "What now?" \
      "Re-enter credentials and retry" \
      "Re-enter all storage fields and retry" \
      "Save anyway (broken storage kept in config)" \
      "Abort and roll back")

    case "$recover" in
      "Re-enter credentials and retry")
        access_key=$(gum input --header "Access key:" --value "$access_key")
        [[ -z "$access_key" ]] && { log_info "Aborted."; storage_delete_block; keychain_delete "s3-secret-key" 2>/dev/null || true; return 1; }
        local new_secret
        new_secret=$(gum input --password --header "S3 secret key:")
        [[ -z "$new_secret" ]] && { log_info "Aborted."; storage_delete_block; keychain_delete "s3-secret-key" 2>/dev/null || true; return 1; }
        keychain_set "s3-secret-key" "$new_secret"
        continue
        ;;
      "Re-enter all storage fields and retry")
        # Re-run provider branch with previous values as defaults.
        provider=$(gum choose --header "Storage provider:" "AWS S3" "S3-compatible (MinIO, R2, B2, ...)")
        if [[ "$provider" == "AWS S3" ]]; then
          endpoint="https://s3.amazonaws.com"
          region=$(gum input --header "AWS region:" --value "${region:-us-east-1}")
        else
          endpoint=$(gum input --header "Endpoint URL:" --value "${endpoint:-}")
          region=$(gum input --header "Region (optional):" --value "${region:-}")
        fi
        bucket=$(gum input --header "Bucket:" --value "${bucket:-}")
        prefix=$(gum input --header "Prefix:" --value "${prefix:-}")
        # Access key is a non-secret "field" (lives plaintext in config), so
        # users picking "all storage fields" reasonably expect to re-enter it.
        # Secret key stays in the vault — use "Re-enter credentials" for that.
        access_key=$(gum input --header "Access key:" --value "${access_key:-}")
        [[ -z "$access_key" ]] && { log_info "Aborted."; storage_delete_block; keychain_delete "s3-secret-key" 2>/dev/null || true; return 1; }
        continue
        ;;
      "Save anyway (broken storage kept in config)")
        log_warn "Storage saved with failing round-trip test. Fix it with: dbx config edit"
        return 0
        ;;
      "Abort and roll back"|"")
        log_info "Rolling back..."
        storage_delete_block
        keychain_delete "s3-secret-key" 2>/dev/null || true
        log_info "Rolled back. Config and vault unchanged."
        return 1
        ;;
    esac
  done

  echo
  log_success "Remote storage configured."
  if [[ "$provider" == "AWS S3" ]]; then
    log_info "  Provider:  AWS S3 (region: $region)"
  else
    log_info "  Provider:  S3-compatible ($endpoint)"
  fi
  log_info "  Bucket:    $bucket"
  log_info "  Prefix:    ${prefix:-(root)}"
  log_info "Try: dbx storage list   (after your first backup uploads)"
}

cmd_storage() {
  local action="${1:-info}"
  shift || true

  case "$action" in
    upload)
      local local_file="${1:-}"
      local remote_path="${2:-}"

      [[ -z "$local_file" ]] && die "Usage: dbx storage upload <local-file> [remote-path]"
      [[ ! -f "$local_file" ]] && die "File not found: $local_file"

      storage_upload "$local_file" "$remote_path"
      ;;

    download)
      local remote_path="${1:-}"
      local local_file="${2:-}"

      [[ -z "$remote_path" ]] && die "Usage: dbx storage download <remote-path> [local-file]"

      local result
      result=$(storage_download "$remote_path" "$local_file")
      log_info "Downloaded to: $result"
      ;;

    list|ls)
      local path="${1:-}"
      storage_list "$path"
      ;;

    delete|rm)
      local remote_path="${1:-}"
      [[ -z "$remote_path" ]] && die "Usage: dbx storage delete <remote-path>"
      storage_delete "$remote_path"
      ;;

    sync)
      local direction="${1:-upload}"
      local host="${2:-}"
      local database="${3:-}"

      case "$direction" in
        upload|up)
          [[ -z "$host" ]] && die "Usage: dbx storage sync upload <host> [database]"
          storage_sync_upload "$host" "$database"
          ;;
        download|down)
          [[ -z "$host" ]] && die "Usage: dbx storage sync download <host> [database]"
          storage_sync_download "$host" "$database"
          ;;
        *)
          die "Usage: dbx storage sync <upload|download> <host> [database]"
          ;;
      esac
      ;;

    add)
      storage_add "$@"
      ;;

    info|"")
      storage_info
      ;;

    *)
      die "Unknown storage action: $action (use: upload, download, list, delete, sync, info, add)"
      ;;
  esac
}

# ============================================================================
# Scrub (PII manifest + drift detection)
# ============================================================================

cmd_scrub() {
  local action="${1:-}"
  shift || true

  case "$action" in
    init)
      _cmd_scrub_init "$@"
      ;;
    check)
      _cmd_scrub_check "$@"
      ;;
    validate)
      _cmd_scrub_validate "$@"
      ;;
    ""|help|-h|--help)
      cat <<EOF
Usage:
  dbx scrub init <host>/<database> [--include-empty] [--output FILE]
  dbx scrub check <host>/<database> [--quiet] [--json]
  dbx scrub validate <host>

  init       Connect to source, walk information_schema, emit a draft
             manifest with dictionary-matched columns. Review, commit,
             then point hosts.<host>.scrub.manifest at the file.
  check      Diff the manifest against the live schema. Exit 0 on clean,
             2 on drift (new PII columns, undeclared JSON, missing
             declared columns), 1 on error. Use in CI nightly.
  validate   Schema-validate the configured manifest file.
EOF
      ;;
    *)
      die "Unknown scrub action: $action (use: init, check, validate)"
      ;;
  esac
}

# Parse a <host>/<database> argument; echoes "host" and "database" on
# separate lines via stdout (caller reads with mapfile or `read -r`).
# Dies on a malformed input.
_parse_scrub_target() {
  local arg="$1"
  [[ -z "$arg" ]] && die "Usage: dbx scrub <action> <host>/<database>"
  [[ "$arg" != */* ]] && die "Target must be in the form <host>/<database> (got: $arg)"
  local host="${arg%%/*}"
  local database="${arg#*/}"
  [[ -z "$host" || -z "$database" ]] && \
    die "Could not parse host/database from '$arg'"
  printf '%s\n%s\n' "$host" "$database"
}

# Dispatch the engine-specific schema query, emitting TSV on stdout.
# Args: $1 host, $2 database
_scrub_query_live_schema_tsv() {
  local host="$1" db="$2"
  local dbtype
  dbtype=$(get_db_type "$host")
  case "$dbtype" in
    postgres|postgresql) scrub_schema_query_pg "$host" "$db" ;;
    mysql|mariadb)       scrub_schema_query_mysql "$host" "$db" ;;
    *) die "scrub: unknown database type for host '$host': $dbtype" ;;
  esac
}

_cmd_scrub_init() {
  local target="" output="" include_empty=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --include-empty) include_empty=true; shift ;;
      --output|-o) output="$2"; shift 2 ;;
      --*|-*) die "Unknown option: $1" ;;
      *) [[ -z "$target" ]] && target="$1" || die "Unexpected argument: $1"; shift ;;
    esac
  done

  require_config
  require_jq
  require_docker

  local host database
  { read -r host; read -r database; } < <(_parse_scrub_target "$target")

  log_step "scrub init: querying schema of $database@$host..."
  local tsv schema draft
  tsv=$(_scrub_query_live_schema_tsv "$host" "$database")
  if [[ -z "$tsv" ]]; then
    die "scrub init: schema query returned no rows (check credentials and database name)"
  fi
  schema=$(printf '%s\n' "$tsv" | scrub_schema_tsv_to_json)

  # Inherit the configured seed_env name (if any) from the existing
  # manifest, so re-running init doesn't fight the user's choice.
  local seed_env="DBX_SCRUB_SEED"
  if scrub_manifest_exists "$host"; then
    local existing
    existing=$(scrub_read_manifest "$host")
    local cfgured
    cfgured=$(jq -r '.seed_env // empty' <<<"$existing")
    [[ -n "$cfgured" ]] && seed_env="$cfgured"
  fi

  draft=$(scrub_init_draft_from_schema "$schema" "$seed_env" "$include_empty")
  # Pretty-print for human consumption.
  local pretty
  pretty=$(jq '.' <<<"$draft")

  if [[ -n "$output" ]]; then
    printf '%s\n' "$pretty" > "$output"
    log_success "Draft manifest written: $output"
    log_info "Review, edit, then point hosts.$host.scrub.manifest at the file."
  else
    printf '%s\n' "$pretty"
    log_info "Re-run with --output PATH to save the draft to a file."
  fi
}

_cmd_scrub_check() {
  local target="" quiet=false as_json=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --quiet|-q) quiet=true; shift ;;
      --json)     as_json=true; shift ;;
      --*|-*)     die "Unknown option: $1" ;;
      *) [[ -z "$target" ]] && target="$1" || die "Unexpected argument: $1"; shift ;;
    esac
  done

  require_config
  require_jq
  require_docker

  local host database
  { read -r host; read -r database; } < <(_parse_scrub_target "$target")

  if ! scrub_manifest_exists "$host"; then
    log_error "scrub check: no manifest configured for host '$host'"
    log_info "Run: dbx scrub init $target --output dbx.scrub.json"
    log_info "Then set hosts.$host.scrub.manifest to that path in your config."
    return 1
  fi

  local mf
  mf=$(scrub_manifest_path "$host")
  # Schema-validate the manifest before drift-checking. A malformed
  # manifest cannot be meaningfully compared against a live schema.
  if ! scrub_validate_manifest "$mf" >/dev/null 2>&1; then
    log_error "scrub check: manifest is invalid — run 'dbx scrub validate $host' for details"
    return 1
  fi

  [[ "$quiet" != "true" ]] && log_step "scrub check: comparing manifest against live schema of $database@$host..."

  local tsv schema manifest report
  tsv=$(_scrub_query_live_schema_tsv "$host" "$database")
  if [[ -z "$tsv" ]]; then
    die "scrub check: schema query returned no rows"
  fi
  schema=$(printf '%s\n' "$tsv" | scrub_schema_tsv_to_json)
  manifest=$(scrub_read_manifest "$host")
  report=$(scrub_check_diff "$schema" "$manifest")

  if [[ "$as_json" == "true" ]]; then
    printf '%s\n' "$report" | jq '.'
    if [[ "$(jq -r '.ok' <<<"$report")" == "true" ]]; then return 0; else return 2; fi
  fi

  # Human-readable report
  if [[ "$(jq -r '.ok' <<<"$report")" == "true" ]]; then
    [[ "$quiet" != "true" ]] && \
      log_success "scrub: $target — manifest is current (no drift)"
    return 0
  fi

  log_error "scrub: $target — DRIFT DETECTED"
  echo ""

  local nc nt nm nju
  nc=$(jq '.new_columns_with_dict_match | length' <<<"$report")
  nt=$(jq '.new_tables_with_dict_matches | length' <<<"$report")
  nm=$(jq '.missing_declared_columns | length' <<<"$report")
  nju=$(jq '.json_columns_undeclared | length' <<<"$report")

  if [[ "$nc" -gt 0 ]]; then
    echo "  NEW dictionary-matching columns (no strategy declared):"
    jq -r '.new_columns_with_dict_match[] |
      "    \(.table).\(.column)\t(pattern: \(.pattern))\tsuggested: \(.suggested.strategy)"' \
      <<<"$report" | column -t -s $'\t'
    echo ""
  fi

  if [[ "$nt" -gt 0 ]]; then
    echo "  NEW tables with dictionary matches (not in manifest):"
    jq -r '.new_tables_with_dict_matches[] |
      "    \(.table):\n" +
      (.matches | map("      · \(.column)\t(pattern: \(.pattern))\tsuggested: \(.suggested.strategy)") | join("\n"))' \
      <<<"$report"
    echo ""
  fi

  if [[ "$nm" -gt 0 ]]; then
    echo "  MISSING declared columns (manifest references a column not in schema — strategy would no-op, PII may leak):"
    jq -r '.missing_declared_columns[] | "    \(.table).\(.column)"' <<<"$report"
    echo ""
  fi

  if [[ "$nju" -gt 0 ]]; then
    echo "  UNDECLARED JSON columns (implicit-deny — declare jsonb_scrub_paths, redact, or passthrough):"
    jq -r '.json_columns_undeclared[] | "    \(.table).\(.column)"' <<<"$report"
    echo ""
  fi

  echo "  This manifest does not cover the current schema. A clone"
  echo "  scrubbed against it may leak PII. Edit $(basename "$mf") and re-run."
  return 2
}

_cmd_scrub_validate() {
  local host="${1:-}"
  [[ -z "$host" ]] && die "Usage: dbx scrub validate <host>"
  require_config
  require_jq
  if ! scrub_manifest_exists "$host"; then
    die "scrub validate: no manifest configured for host '$host'"
  fi
  local mf
  mf=$(scrub_manifest_path "$host")
  if scrub_validate_manifest "$mf"; then
    log_success "Manifest schema valid: $mf"
    return 0
  else
    return 1
  fi
}

cmd_query() {
  local host="${1:-}"
  local database="${2:-}"

  [[ -z "$host" ]] && die "Usage: dbx query <host> [database]"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  # Create SSH tunnel if configured
  if has_ssh_tunnel "$host"; then
    create_ssh_tunnel "$host"
  fi

  local db_type db_host db_port db_user db_pass
  db_type=$(get_db_type "$host")
  db_host=$(get_effective_host "$host")
  db_port=$(get_effective_port "$host")
  db_user=$(get_config_value ".hosts[\"$host\"].user")
  db_pass=$(get_password "$host")

  log_step "Connecting to $host ($db_type)"
  log_info "Host: $db_host:$db_port, User: $db_user"
  [[ -n "$database" ]] && log_info "Database: $database"

  case "$db_type" in
    postgres|postgresql)
      require_container "$POSTGRES_CONTAINER"
      if [[ -n "$database" ]]; then
        docker exec -it -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
          psql -h "$db_host" -p "$db_port" -U "$db_user" -d "$database"
      else
        docker exec -it -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
          psql -h "$db_host" -p "$db_port" -U "$db_user"
      fi
      ;;
    mysql|mariadb)
      require_container "$MYSQL_CONTAINER"
      if [[ -n "$database" ]]; then
        docker exec -it -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
          mysql -h "$db_host" -P "$db_port" -u "$db_user" "$database"
      else
        docker exec -it -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
          mysql -h "$db_host" -P "$db_port" -u "$db_user"
      fi
      ;;
    *)
      die "Unknown database type: $db_type"
      ;;
  esac
}

cmd_test() {
  local host="${1:-}"

  [[ -z "$host" ]] && die "Usage: dbx test <host>"

  require_config
  require_jq
  require_docker

  local host_config
  host_config=$(get_host_config "$host")
  [[ -z "$host_config" ]] && die "Host '$host' not found in config"

  log_step "Testing connection to: $host"

  local db_type db_host db_port db_user
  db_type=$(get_db_type "$host")
  db_host=$(get_config_value ".hosts[\"$host\"].host")
  db_port=$(get_config_value ".hosts[\"$host\"].port")
  db_user=$(get_config_value ".hosts[\"$host\"].user")

  # Test 1: SSH tunnel (if configured)
  if has_ssh_tunnel "$host"; then
    log_info "SSH tunnel configured"
    if create_ssh_tunnel "$host"; then
      log_success "SSH tunnel established"
    else
      log_error "SSH tunnel failed"
      return 1
    fi
    db_host=$(get_effective_host "$host")
    db_port=$(get_effective_port "$host")
  else
    log_info "No SSH tunnel (direct connection)"
  fi

  # Test 2: Docker container
  case "$db_type" in
    postgres|postgresql)
      log_info "Checking PostgreSQL container..."
      require_container "$POSTGRES_CONTAINER"
      log_success "Container ready: $POSTGRES_CONTAINER"
      ;;
    mysql|mariadb)
      log_info "Checking MySQL container..."
      require_container "$MYSQL_CONTAINER"
      log_success "Container ready: $MYSQL_CONTAINER"
      ;;
  esac

  # Test 3: Credentials
  local db_pass
  db_pass=$(get_password "$host" 2>/dev/null || true)
  if [[ -n "$db_pass" ]]; then
    log_success "Credentials found"
  else
    log_error "No credentials found for '$host'"
    log_info "Set with: dbx vault set $host"
    return 1
  fi

  # Test 4: Database connectivity
  log_info "Testing database connection..."
  case "$db_type" in
    postgres|postgresql)
      if docker exec -e PGPASSWORD="$db_pass" "$POSTGRES_CONTAINER" \
        psql -h "$db_host" -p "$db_port" -U "$db_user" -c "SELECT 1" >/dev/null 2>&1; then
        log_success "PostgreSQL connection successful"
      else
        log_error "PostgreSQL connection failed"
        return 1
      fi
      ;;
    mysql|mariadb)
      if docker exec -e MYSQL_PWD="$db_pass" "$MYSQL_CONTAINER" \
        mysqladmin ping -h "$db_host" -P "$db_port" -u "$db_user" >/dev/null 2>&1; then
        log_success "MySQL connection successful"
      else
        log_error "MySQL connection failed"
        return 1
      fi
      ;;
  esac

  # Test 5: List available databases
  log_info "Available databases:"
  list_remote_databases "$host" 2>/dev/null | while read -r dbname; do
    [[ -n "$dbname" ]] && echo "  - $dbname"
  done

  echo ""
  log_success "All connection tests passed for: $host"
}


cmd_update() {
  log_step "Updating dbx..."
  log_info "Re-running install.sh from ${DBX_REPO_SLUG}@main"
  curl -fsSL "https://raw.githubusercontent.com/${DBX_REPO_SLUG}/main/install.sh" | bash
}

# Prompt for a TCP port and validate it's numeric. Re-prompts on
# non-numeric input. Empty input returns non-zero so callers can abort.
# Args: $1 prompt header, $2 default value. Prints the validated port.
host_prompt_port() {
  local header="$1" default="$2" port
  while :; do
    port=$(gum input --header "$header" --value "$default")
    [[ -z "$port" ]] && return 1
    if [[ "$port" =~ ^[0-9]+$ ]]; then
      echo "$port"
      return 0
    fi
    log_warn "Port must be a number (got: $port)"
  done
}

# Write a host block to $CONFIG_FILE atomically via jq + temp-file.
# Args: alias, type, user, then either:
#   "direct" <host> <port>
#   "tunnel" <jump_host> <target_host> <target_port>
host_write_block() {
  local alias="$1" type="$2" user="$3" mode="$4"
  local tmp; tmp=$(mktemp)
  if [[ "$mode" == "direct" ]]; then
    local h="$5" p="$6"
    jq --arg a "$alias" --arg t "$type" --arg u "$user" \
       --arg h "$h" --argjson p "$p" \
       '.hosts[$a] = {type: $t, host: $h, port: $p, user: $u, databases: {}}' \
       "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  else
    local jh="$5" th="$6" tp="$7"
    jq --arg a "$alias" --arg t "$type" --arg u "$user" \
       --arg jh "$jh" --arg th "$th" --argjson tp "$tp" \
       '.hosts[$a] = {type: $t, user: $u, ssh_tunnel: {jump_host: $jh, target_host: $th, target_port: $tp}, databases: {}}' \
       "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  fi
  secure_file "$CONFIG_FILE"
}

# Delete a host block from $CONFIG_FILE. Used by the wizard's rollback path.
host_delete_block() {
  local alias="$1"
  local tmp; tmp=$(mktemp)
  jq --arg a "$alias" 'del(.hosts[$a])' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  secure_file "$CONFIG_FILE"
}

host_add() {
  require_config
  require_jq
  require_docker
  require_gum

  local alias new_type new_user
  while :; do
    alias=$(gum input --header "Host alias:" --placeholder "production")
    [[ -z "$alias" ]] && { log_info "Aborted."; return 0; }
    if ! host_alias_valid "$alias"; then
      log_warn "Alias must start with a letter or digit and use only letters, digits, '_', or '-'."
      continue
    fi
    if host_exists "$alias"; then
      local existing_type existing_user
      existing_type=$(get_config_value ".hosts[\"$alias\"].type")
      existing_user=$(get_config_value ".hosts[\"$alias\"].user")
      log_warn "Host '$alias' already exists (type=$existing_type, user=$existing_user)."
      continue
    fi
    break
  done

  new_type=$(gum choose --header "Database type:" "postgres" "mysql")
  [[ -z "$new_type" ]] && { log_info "Aborted."; return 0; }

  new_user=$(gum input --header "Database user:" --placeholder "postgres")
  [[ -z "$new_user" ]] && { log_info "Aborted."; return 0; }

  local network_mode
  network_mode=$(gum choose --header "How does dbx reach this database?" \
    "Direct connection" "SSH tunnel (jump host)")
  [[ -z "$network_mode" ]] && { log_info "Aborted."; return 0; }

  local default_port direct_host direct_port
  local tunnel_jump tunnel_target tunnel_port
  default_port=$([[ "$new_type" == "postgres" ]] && echo "5432" || echo "3306")

  if [[ "$network_mode" == "Direct connection" ]]; then
    direct_host=$(gum input --header "Host address:" --value "localhost")
    [[ -z "$direct_host" ]] && { log_info "Aborted."; return 0; }
    direct_port=$(host_prompt_port "Port:" "$default_port") \
      || { log_info "Aborted."; return 0; }
  else
    tunnel_jump=$(gum input --header "SSH jump host (from your ~/.ssh/config):" \
                            --placeholder "bastion")
    [[ -z "$tunnel_jump" ]] && { log_info "Aborted."; return 0; }
    tunnel_target=$(gum input --header "Database hostname (as seen from the jump host):" \
                              --placeholder "db.internal")
    [[ -z "$tunnel_target" ]] && { log_info "Aborted."; return 0; }
    tunnel_port=$(host_prompt_port "Database port (on the jump-side network):" "$default_port") \
      || { log_info "Aborted."; return 0; }
  fi

  # Credentials. keychain_set persists via the active backend (Keychain on
  # macOS, pass on Linux, age fallback) so the password never lands in
  # config.json.
  local existing_pass
  existing_pass=$(get_password "$alias" 2>/dev/null || true)
  if [[ -n "$existing_pass" ]]; then
    local creds_choice
    creds_choice=$(gum choose --header "Vault already has a password for '$alias'." \
                              "Use existing" "Replace")
    [[ -z "$creds_choice" ]] && { log_info "Aborted."; return 0; }
    if [[ "$creds_choice" == "Replace" ]]; then
      local new_pass
      new_pass=$(gum input --password --header "New password for '$alias':")
      [[ -z "$new_pass" ]] && { log_info "Aborted."; return 0; }
      keychain_set "$alias" "$new_pass"
    fi
  else
    local new_pass
    new_pass=$(gum input --password --header "Password for '$alias':")
    [[ -z "$new_pass" ]] && { log_info "Aborted."; return 0; }
    keychain_set "$alias" "$new_pass"
  fi

  log_info "Credentials stored."

  while :; do
    log_step "Writing provisional host block and validating..."
    if [[ "$network_mode" == "Direct connection" ]]; then
      host_write_block "$alias" "$new_type" "$new_user" direct "$direct_host" "$direct_port"
    else
      host_write_block "$alias" "$new_type" "$new_user" tunnel \
        "$tunnel_jump" "$tunnel_target" "$tunnel_port"
    fi

    if cmd_test "$alias"; then
      log_success "Connection validated."
      break
    fi

    log_error "Connection validation failed."
    local recover
    recover=$(gum choose --header "What now?" \
      "Re-enter credentials and retry" \
      "Re-enter host fields and retry" \
      "Save anyway (broken host kept in config)" \
      "Abort and roll back")

    case "$recover" in
      "Re-enter credentials and retry")
        local new_pass
        new_pass=$(gum input --password --header "New password for '$alias':")
        [[ -z "$new_pass" ]] && { log_info "Aborted."; host_delete_block "$alias"; keychain_delete "$alias" 2>/dev/null || true; return 1; }
        keychain_set "$alias" "$new_pass"
        continue
        ;;
      "Re-enter host fields and retry")
        # Re-collect network branch only; identity stays.
        network_mode=$(gum choose --header "How does dbx reach this database?" \
          "Direct connection" "SSH tunnel (jump host)")
        [[ -z "$network_mode" ]] && { log_info "Aborted."; host_delete_block "$alias"; keychain_delete "$alias" 2>/dev/null || true; return 1; }
        if [[ "$network_mode" == "Direct connection" ]]; then
          direct_host=$(gum input --header "Host address:" --value "${direct_host:-localhost}")
          direct_port=$(host_prompt_port "Port:" "${direct_port:-$default_port}") \
            || { log_info "Aborted."; host_delete_block "$alias"; keychain_delete "$alias" 2>/dev/null || true; return 1; }
        else
          tunnel_jump=$(gum input --header "SSH jump host:" --value "${tunnel_jump:-}")
          tunnel_target=$(gum input --header "Database hostname:" --value "${tunnel_target:-}")
          tunnel_port=$(host_prompt_port "Database port:" "${tunnel_port:-$default_port}") \
            || { log_info "Aborted."; host_delete_block "$alias"; keychain_delete "$alias" 2>/dev/null || true; return 1; }
        fi
        continue
        ;;
      "Save anyway (broken host kept in config)")
        log_warn "Host '$alias' saved with failing connection test. Fix it with: dbx config edit"
        return 0
        ;;
      "Abort and roll back"|"")
        log_info "Rolling back..."
        host_delete_block "$alias"
        keychain_delete "$alias" 2>/dev/null || true
        log_info "Rolled back. Config and vault unchanged."
        return 1
        ;;
    esac
  done

  local remote_dbs picked
  remote_dbs=$(list_remote_databases "$alias" 2>/dev/null | grep -v '^$' || true)

  if [[ -z "$remote_dbs" ]]; then
    log_warn "No user databases found on '$alias' (or list query failed)."
    log_info "Continuing with empty database list — edit them later via 'dbx config edit'."
    picked=""
  else
    picked=$(echo "$remote_dbs" | gum choose --no-limit \
      --header "Pick databases to back up (space to toggle, enter to confirm):")
    if [[ -z "$picked" ]]; then
      log_info "No databases selected."
    fi
  fi

  # Per-database exclude tables.
  if [[ -n "$picked" ]]; then
    while IFS= read -r db; do
      [[ -z "$db" ]] && continue
      local excl
      excl=$(gum input --header "Tables to exclude data from in '$db' (comma-separated, blank for none):")
      local tmp; tmp=$(mktemp)
      if [[ -n "$excl" ]]; then
        local excl_json
        excl_json=$(printf '%s' "$excl" | tr ',' '\n' \
          | awk 'NF { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); print }' \
          | jq -R . | jq -s .)
        jq --arg a "$alias" --arg d "$db" --argjson e "$excl_json" \
           '.hosts[$a].databases[$d] = {exclude_data: $e}' \
           "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
      else
        jq --arg a "$alias" --arg d "$db" \
           '.hosts[$a].databases[$d] = {}' \
           "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
      fi
      secure_file "$CONFIG_FILE"
    done <<< "$picked"
  fi

  # MySQL-only: strip DEFINER clauses? Default yes.
  if [[ "$new_type" == "mysql" ]]; then
    local definer_value
    if gum confirm --default=true "Strip DEFINER clauses from MySQL dumps?"; then
      definer_value="strip"
    else
      definer_value="keep"
    fi
    local tmp; tmp=$(mktemp)
    jq --arg a "$alias" --arg dh "$definer_value" \
       '.hosts[$a].definer_handling = $dh' \
       "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
    secure_file "$CONFIG_FILE"
  fi

  # Summary.
  local db_count
  db_count=$(printf '%s' "$picked" | grep -c . || true)
  echo
  log_success "Host '$alias' added."
  log_info "  Type:      $new_type"
  if [[ "$network_mode" == "Direct connection" ]]; then
    log_info "  Network:   direct ($direct_host:$direct_port)"
  else
    log_info "  Network:   ssh tunnel via $tunnel_jump to $tunnel_target:$tunnel_port"
  fi
  log_info "  Databases: ${db_count:-0}"

  # Storage chain (conditional). See spec: "Step 7 — Storage chain".
  if is_storage_configured; then
    if gum confirm --default=false "Enable auto-upload to remote storage for '$alias' backups?"; then
      local tmp; tmp=$(mktemp)
      jq --arg a "$alias" '.hosts[$a].auto_upload = true' \
        "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
      secure_file "$CONFIG_FILE"
      log_info "  Storage:   auto-upload enabled for $alias"
    else
      log_info "  Storage:   configured globally (auto-upload off for $alias)"
    fi
  else
    if gum confirm --default=true "Configure remote storage for these backups now?"; then
      storage_add
    else
      log_info "  Storage:   not configured (skipped). Set up later with: dbx storage add"
    fi
  fi

  log_info "Try: dbx backup $alias"
}

cmd_host() {
  local action="${1:-}"; shift || true
  case "$action" in
    add)
      host_add "$@"
      ;;
    remove|rm|delete|list|ls|test|edit)
      die "host $action: not yet implemented"
      ;;
    ""|help)
      die "Usage: dbx host <action>
  Actions:
    add        Interactively add a new backup host"
      ;;
    *)
      die "Unknown host action: $action (use: add)"
      ;;
  esac
}

cmd_help() {
  cat <<EOF
${BOLD}dbx${NC} - Database backup and restore utility

${BOLD}USAGE:${NC}
  dbx <command> [options]

${BOLD}COMMANDS:${NC}
  backup [-v] [--upload] <host> [database]  Backup database(s) (-v verbose)
  restore <source> [--name N] [--no-post-restore | --hooks-only] [--no-scrub] [--transform=PATH] [--into NAME]  Restore a backup
                               <source> can be a local file, host/db/latest,
                               s3://host/db/latest, or use --from-remote PATH
                               --transform pipes the restore through a host script (runs under env -i; use --transform-inherit-env to opt out)
                               --into targets a named running container instead of the managed postgres-dbx (postgres only)
  verify [backup-file]         Verify backup integrity (checksum)
  query <host> [database]      Open interactive shell to remote database
  analyze <host> <database>    Interactive table analysis & exclusion picker
  test <host>                  Test connection to a database host
  host add                     Interactively add a host (alias, creds, validate, pick dbs)
  wizard                       Browser-based config wizard (auto-falls back to gum if no GUI)
  list [host] [database]       List available backups
  clean [--keep N] [--dry-run] [--older-than D]  Remove old backups
  update                       Re-run install.sh to upgrade to the latest release

${BOLD}CREDENTIAL & ENCRYPTION:${NC}
  vault set|get|delete|list    Manage host credentials
  vault info                   Show vault backend info
  vault set-encryption-key     Set GPG encryption passphrase
  vault init-age               Initialize age encryption

${BOLD}SCHEDULING & STORAGE:${NC}
  schedule add|remove|list|sync  Manage scheduled backups (launchd/systemd; sync reconciles config.schedules[])
  storage upload|download|sync S3/MinIO cloud storage
  storage add                  Interactively configure remote storage (S3/MinIO) + live test
  storage info                 Show storage configuration
  config init|edit|show|validate  Manage configuration

${BOLD}PII SCRUB:${NC}
  scrub init <host>/<db>       Walk live schema, emit draft scrub manifest
  scrub check <host>/<db>      Drift check (CI-friendly: exit 2 on drift)
  scrub validate <host>        Schema-validate the configured manifest

${BOLD}EXAMPLES:${NC}
  # Setup
  dbx config init              # Create config template
  dbx config edit              # Add your hosts
  dbx vault set production     # Store password securely

  # Enable encryption (optional - GPG or age)
  dbx vault set-encryption-key # Set GPG encryption passphrase
  dbx vault init-age           # Or use age encryption
  # Then set "encryption_type": "gpg" or "age" in config

  # Backup (auto SSH tunnel if configured)
  dbx backup production myapp
  dbx backup staging myapp

  # Verify backup integrity
  dbx verify production/myapp/latest

  # Restore to local container
  dbx restore production/myapp/latest
  dbx restore staging/myapp/latest --name myapp_copy

  # Restore directly from S3/MinIO (no separate \`storage download\` step)
  dbx restore --from-remote production/myapp/latest
  dbx restore s3://production/myapp/latest --name myapp_copy
  dbx restore --from-remote prod/db/db_20260510_120000.sql.zst.age --keep-download

  # Schedule backups
  dbx schedule add production myapp daily   # Run daily at 2am
  dbx schedule add prod db weekly@0:3       # Sunday at 3am
  dbx schedule list                         # Show scheduled jobs
  dbx schedule sync                         # Preview reconcile config.schedules[] vs installed (read-only)

  # Cloud storage
  dbx storage info                          # Show S3/MinIO config
  dbx storage sync upload production        # Upload all backups for host
  dbx storage list                          # List remote backups

  # Interactive query session
  dbx query production                  # Connect to host
  dbx query production myapp            # Connect to specific database

  # Manage
  dbx list                     # Show all hosts
  dbx list production          # Show databases for host
  dbx clean --keep 5           # Keep only 5 latest per database
  dbx clean --older-than 30    # Remove backups older than 30 days
  dbx clean --keep 3 --older-than 30  # Keep 3 newest, remove older beyond

${BOLD}CONFIG STRUCTURE:${NC}
  {
    "hosts": { ... },
    "defaults": {
      "encryption_type": "age",   // none, gpg, or age
      "age_recipients": "~/.config/dbx/age-recipients.txt"
    },
    "vault": {
      "backend": "auto"           // keychain, secret-tool, pass, gpg-file
    },
    "notifications": {
      "enabled": true,
      "on": "failure",            // failure, success, all
      "backends": ["slack", "desktop"]
    },
    "storage": {
      "type": "s3",
      "s3": {
        "bucket": "backups",
        "endpoint": "http://minio:9000"
      }
    },
    "schedules": [
      { "host": "production", "database": "myapp", "when": "daily@5" }
    ]
  }

${BOLD}FEATURES:${NC}
  - SSH tunnels: Auto-creates tunnel for remote DBs, cleans up on exit
  - Encryption: GPG or age encryption at rest
  - Checksums: SHA256 verification for backup integrity
  - DEFINER strip: MySQL views/triggers work locally
  - Exclude tables: Dump schema but skip data for large/sensitive tables
  - Credential storage: macOS Keychain, Linux secret-tool, pass, or GPG file
  - Scheduled backups: launchd (macOS) or systemd timers (Linux)
  - Cloud storage: S3/MinIO upload and sync
  - Notifications: Slack, desktop, email on backup success/failure
  - Audit logging: JSON audit trail at ~/.local/share/dbx/audit.log

${BOLD}STORAGE:${NC}
  Backups:  ~/.data/dbx/<host>/<database>/<database>_<timestamp>.sql.zst[.age|.gpg]
  Config:   ~/.config/dbx/config.json
  Audit:    ~/.local/share/dbx/audit.log
  Secrets:  macOS Keychain, Linux secret-tool, pass, or ~/.config/dbx/vault.gpg

${BOLD}REQUIREMENTS:${NC}
  - docker (for pg_dump/mysqldump containers)
  - jq, zstd, ssh
  - gpg or age (optional, for encryption)
  - mc or aws CLI (optional, for S3 storage)
EOF
}

# ============================================================================
# Main
# ============================================================================

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    backup)
      cmd_backup "$@"
      ;;
    restore)
      cmd_restore "$@"
      ;;
    verify)
      cmd_verify "$@"
      ;;
    test|ping)
      cmd_test "$@"
      ;;
    host)
      cmd_host "$@"
      ;;
    wizard)
      cmd_wizard "$@"
      ;;
    analyze|stats)
      cmd_analyze "$@"
      ;;
    query|q|shell)
      cmd_query "$@"
      ;;
    list|ls)
      cmd_list "$@"
      ;;
    clean|prune)
      cmd_clean "$@"
      ;;
    vault)
      cmd_vault "$@"
      ;;
    config|cfg)
      cmd_config "$@"
      ;;
    schedule|cron)
      cmd_schedule "$@"
      ;;
    storage|s3)
      cmd_storage "$@"
      ;;
    scrub)
      cmd_scrub "$@"
      ;;
    help|--help|-h)
      cmd_help
      ;;
    version|--version|-V)
      echo "dbx $VERSION"
      ;;
    update|self-update|upgrade)
      cmd_update
      ;;
    *)
      die "Unknown command: $cmd (run 'dbx help' for usage)"
      ;;
  esac

  # After every interactive command, hint at a newer release if one
  # exists. Self-gated to TTY only; cached so the API is hit at most
  # once per UPDATE_CHECK_INTERVAL_SECONDS.
  maybe_notify_update
}

# Tests source this file to access cmd_* functions without executing
# the full CLI dispatch; set DBX_NO_AUTO_MAIN=1 to skip the top-level run.
if [[ -z "${DBX_NO_AUTO_MAIN:-}" ]]; then
  main "$@"
fi
